.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary);
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary);
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-accent);
}

.header-user {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.messages-container {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-tertiary);
  border-radius: 50%;
  font-size: 40rpx;
  flex-shrink: 0;
}

.message-content {
  max-width: 70%;
  margin: 0 16rpx;
}

.message-text {
  display: block;
  padding: 20rpx 24rpx;
  border-radius: 12px;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.user .message-text {
  background-color: var(--color-accent);
  color: #fff;
}

.assistant .message-text {
  background-color: var(--color-bg-secondary);
  color: var(--color-text-primary);
}

.saved-indicator {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.revoke-btn {
  margin-left: 16rpx;
  color: var(--color-accent);
}

.message-time {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.loading-indicator {
  padding: 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.input-area {
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-secondary);
  border-top: 1px solid var(--color-border);
  flex-shrink: 0;
}

.input-container {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-tertiary);
  border-radius: 40rpx;
  padding: 8rpx 16rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
}

.input-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-left: 8rpx;
}

.voice-btn.recording {
  color: var(--color-accent-red);
}

.send-btn {
  color: var(--color-accent);
}