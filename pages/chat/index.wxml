<view class="chat-page">
  <!-- Header -->
  <view class="chat-header">
    <text class="header-title">FitLC</text>
    <text class="header-user">{{user.email}}</text>
  </view>

  <!-- Messages -->
  <scroll-view
    class="messages-container"
    scroll-y
    scroll-top="{{scrollTop}}"
  >
    <view
      wx:for="{{messages}}"
      wx:key="id"
      class="message-item {{item.role}}"
    >
      <view class="message-avatar">
        <text>{{item.role === 'user' ? '👤' : '🤖'}}</text>
      </view>
      <view class="message-content">
        <text class="message-text">{{item.content}}</text>
        <view wx:if="{{item.savedData}}" class="saved-indicator">
          <text>✓ 已保存</text>
          <text class="revoke-btn" data-id="{{item.id}}" bindtap="onMessageTap">撤销</text>
        </view>
        <text class="message-time">{{formatTime(item.timestamp)}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- Loading -->
  <view wx:if="{{isLoading}}" class="loading-indicator">
    <text>AI 处理中...</text>
  </view>

  <!-- Input Area -->
  <view class="input-area">
    <view class="input-container">
      <input
        class="chat-input"
        value="{{inputValue}}"
        placeholder="输入训练内容..."
        bindinput="onInput"
        bindconfirm="onSend"
      />
      <view class="input-actions">
        <text class="action-btn voice-btn {{isRecording ? 'recording' : ''}}" bindtap="onVoiceTap">
          {{isRecording ? '⏹' : '🎤'}}
        </text>
        <text class="action-btn image-btn" bindtap="onImageTap">📷</text>
        <text class="action-btn send-btn" bindtap="onSend">➤</text>
      </view>
    </view>
  </view>
</view>