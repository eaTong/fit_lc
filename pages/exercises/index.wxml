<view class="exercises-page">
  <!-- Header -->
  <view class="exercises-header">
    <view class="search-bar">
      <input
        class="search-input"
        placeholder="搜索动作..."
        value="{{searchKeyword}}"
        bindinput="onSearch"
      />
    </view>
    <view class="header-actions">
      <text class="action-btn" bindtap="onMuscleTreeToggle">
        {{showMuscleTree ? '收起' : '肌肉'}}
      </text>
      <text class="action-btn" bindtap="onMusclePageTap">肌肉库</text>
    </view>
  </view>

  <!-- Muscle Tree (Left Sidebar) -->
  <view wx:if="{{showMuscleTree}}" class="muscle-tree">
    <view
      class="muscle-item all {{selectedMuscleId === null ? 'active' : ''}}"
      bindtap="onAllMuscles"
    >
      <text>全部动作</text>
    </view>
    <block wx:for="{{muscleHierarchy}}" wx:key="id">
      <view class="muscle-group">
        <view
          class="muscle-item parent {{selectedMuscleId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onMuscleSelect"
        >
          <text>{{item.name}}</text>
        </view>
        <view wx:if="{{item.children}}" class="muscle-children">
          <view
            wx:for="{{item.children}}"
            wx:key="id"
            class="muscle-item child {{selectedMuscleId === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="onMuscleSelect"
          >
            <text>{{item.name}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- Exercise Grid -->
  <scroll-view class="exercise-list" scroll-y>
    <view class="exercise-grid">
      <view
        wx:for="{{getFilteredExercises()}}"
        wx:key="id"
        class="exercise-card"
        data-id="{{item.id}}"
        bindtap="onExerciseTap"
      >
        <view class="exercise-name">{{item.name}}</view>
        <view class="exercise-info">
          <text class="tag">{{item.category}}</text>
          <text class="tag">{{item.equipment}}</text>
          <text class="tag difficulty-{{item.difficulty}}">{{item.difficulty}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="{{!loading && getFilteredExercises().length === 0}}" class="empty">
      暂无动作
    </view>
  </scroll-view>
</view>