# =============================================
# FitLC 后端环境配置
# =============================================
# 复制此文件为 .env 并填写实际值
# 不要将 .env 提交到版本控制

# ============ 服务配置 ============
PORT=3000                           # 服务端口
CORS_ORIGIN=http://localhost:5173   # CORS 允许的前端 origin（开发环境）

# ============ 数据库配置 ============
# Prisma 数据库连接字符串（优先使用）
DATABASE_URL="mysql://user:password@localhost:3306/fitlc"

# 备用：单独配置（Prisma 主要读取 DATABASE_URL）
DB_HOST=localhost                   # 数据库主机
DB_PORT=3306                        # 数据库端口
DB_USER=root                        # 数据库用户名
DB_PASSWORD=yourpassword            # 数据库密码
DB_NAME=fitlc                       # 数据库名称

# ============ 认证配置 ============
JWT_SECRET=your-jwt-secret-key      # JWT 签名密钥（生产环境需足够随机）
BCRYPT_SALT_ROUNDS=10               # 密码加密轮数（数值越高越安全但越慢）

# ============ AI 配置 ============
# AI 服务提供商：minimax | zhipu
AI_PROVIDER=minimax

# MiniMax API 密钥（当 AI_PROVIDER=minimax 时使用）
MINIMAX_API_KEY=your-minimax-api-key

# 智谱 GLM API 密钥（当 AI_PROVIDER=zhipu 时使用）
ZHIPU_API_KEY=your-zhipu-api-key

# 可选：覆盖默认模型名称
# AI_MODEL_NAME=GLM-4-Plus  # For text chat
# AI_MODEL_NAME=GLM-4V-Flash  # For vision/multimodal

# ============ OSS 对象存储配置 ============
NODE_ENV=development                # 运行环境：development | production
OSS_REGION=oss-cn-shanghai           # 阿里云 OSS 区域
OSS_ACCESS_KEY_ID=your-access-key-id       # 阿里云 AccessKey ID
OSS_ACCESS_KEY_SECRET=your-access-key-secret  # 阿里云 AccessKey Secret
OSS_BUCKET=fitlc                    # OSS Bucket 名称
