.history-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary, #0A0A0A);
}

.history-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary, #FFFFFF);
}

/* Tab Container */
.tab-container {
  display: flex;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
  transition: color 0.15s ease;
}

.tab-item.active .tab-text {
  color: var(--color-accent, #FF4500);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: var(--color-accent, #FF4500);
  border-radius: 2rpx;
}

/* Loading */
.loading-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
}

/* Empty State */
.empty-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-secondary, #888888);
}

/* Records Container */
.records-container {
  flex: 1;
  padding: 16rpx 24rpx;
}

/* Record Item */
.record-item {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-radius: 4rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1px solid var(--color-border, #333333);
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: var(--color-bg-tertiary, #252525);
  border-radius: 4rpx;
  font-size: 40rpx;
  flex-shrink: 0;
}

.record-content {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.record-type {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
}

.record-date {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
}

.record-summary {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 4rpx;
}

.record-detail {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-arrow {
  width: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--color-text-secondary, #888888);
  font-size: 28rpx;
}