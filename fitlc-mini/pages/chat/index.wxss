.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary);
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary);
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-accent);
}

.header-user {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.messages-container {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  background-color: var(--color-bg-primary);
  border-left: 1rpx solid var(--color-border);
  border-right: 1rpx solid var(--color-border);
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
  padding: 16rpx 20rpx;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-bg-tertiary), var(--color-bg-secondary));
  border-radius: 50%;
  font-size: 40rpx;
  flex-shrink: 0;
  border: 2rpx solid var(--color-border);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  overflow: hidden;
}

.message-avatar.assistant {
  background: linear-gradient(135deg, var(--color-accent), #DC143C);
}

.avatar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.message-content {
  max-width: 80%;
  margin: 0 16rpx;
}

.assistant .message-content {
  background: linear-gradient(135deg, rgba(255, 69, 0, 0.05), rgba(220, 20, 60, 0.05));
}

.message-images {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.message-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  border: 2rpx solid var(--color-border);
}

.message-text {
  display: block;
  padding: 22rpx 28rpx;
  border-radius: 14px;
  font-size: 32rpx;
  line-height: 1.5;
  word-break: break-all;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.user .message-text {
  background-color: var(--color-accent);
  color: #fff;
  box-shadow: 0 2rpx 12rpx rgba(255, 69, 0, 0.3);
}

.assistant .message-text {
  background-color: var(--color-bg-secondary);
  color: var(--color-text-primary);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 工具卡片包装器 */
.tool-card-wrapper {
  margin-bottom: 12rpx;
}

.saved-indicator {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.revoke-btn {
  margin-left: 16rpx;
  color: var(--color-accent);
}

.message-time {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.loading-indicator {
  padding: 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.input-area {
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-secondary);
  border-top: 1px solid var(--color-border);
  flex-shrink: 0;
}

.pending-images {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 0;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 16rpx;
}

.pending-image-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.pending-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--color-border);
}

.pending-image-item .remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(255, 0, 0, 0.8);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input-container {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-tertiary);
  border-radius: 40rpx;
  padding: 8rpx 16rpx;
}

.chat-textarea {
  flex: 1;
  min-height: 80rpx;
  max-height: 200rpx;
  padding: 16rpx 20rpx;
  font-size: 32rpx;
  line-height: 1.5;
  background-color: transparent;
}

.chat-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
}

.input-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-left: 8rpx;
}

.voice-btn.recording {
  color: var(--color-accent-red);
}

.voice-mode {
  justify-content: flex-start;
}

.voice-hint {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-tertiary);
  border-radius: 40rpx;
  margin: 0 8rpx;
}

.voice-hint.recording {
  color: var(--color-accent-red);
  background-color: rgba(220, 20, 60, 0.1);
}

.send-btn {
  color: var(--color-accent);
}