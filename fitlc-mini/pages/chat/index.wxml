<view class="chat-page">
  <!-- Messages -->
  <scroll-view
    class="messages-container"
    scroll-y
    scroll-top="{{scrollTop}}"
  >
    <view
      wx:for="{{messages}}"
      wx:key="id"
      class="message-item {{item.role}}"
    >
      <view class="message-avatar {{item.role}}">
        <image wx:if="{{item.role === 'user' && user.avatar}}" class="avatar-img" src="{{user.avatar}}" mode="aspectFill" />
        <image wx:elif="{{item.role === 'assistant'}}" class="avatar-img" src="/assets/logo.png" mode="aspectFill" />
        <text wx:else>{{item.role === 'user' ? '👤' : ''}}</text>
      </view>
      <view class="message-content {{item.role}}">
        <!-- 用户消息的图片 -->
        <view wx:if="{{item.imageUrls && item.imageUrls.length > 0}}" class="message-images">
          <image
            wx:for="{{item.imageUrls}}"
            wx:key="*this"
            src="{{item}}"
            mode="aspectFill"
            class="message-image"
          />
        </view>
        <text class="message-text">{{item.content}}</text>
        <view wx:if="{{item.savedData}}" class="saved-indicator">
          <text>✓ 已保存</text>
          <text class="revoke-btn" data-id="{{item.id}}" bindtap="onMessageTap">撤销</text>
        </view>
        <text class="message-time">{{formatTime(item.createdAt)}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- Loading -->
  <view wx:if="{{isLoading}}" class="loading-indicator">
    <text>AI 处理中...</text>
  </view>

  <!-- Input Area -->
  <view class="input-area">
    <!-- 待发送图片预览 -->
    <view wx:if="{{pendingImages.length > 0}}" class="pending-images">
      <view wx:for="{{pendingImages}}" wx:key="*this" class="pending-image-item">
        <image src="{{item.path}}" mode="aspectFill" class="pending-image" />
        <text class="remove-btn" data-index="{{index}}" bindtap="onRemovePendingImage">×</text>
      </view>
    </view>

    <!-- 文字模式 -->
    <view wx:if="{{inputMode === 'text'}}" class="input-container">
      <text class="action-btn switch-btn" bindtap="onSwitchMode">🎤</text>
      <textarea
        class="chat-textarea"
        value="{{inputValue}}"
        placeholder="输入训练内容..."
        bindinput="onInput"
        auto-height
        maxlength="2000"
      />
      <view class="input-actions">
        <text class="action-btn image-btn" bindtap="onImageTap">📷</text>
        <text class="action-btn send-btn" bindtap="onSend">➤</text>
      </view>
    </view>

    <!-- 语音模式 -->
    <view wx:if="{{inputMode === 'voice'}}" class="input-container voice-mode">
      <text class="action-btn switch-btn" bindtap="onSwitchMode">⌨️</text>
      <view
        class="voice-hint {{isRecording ? 'recording' : ''}}"
        catchtouchstart="onVoiceTouchStart"
        catchtouchend="onVoiceTouchEnd"
      >
        <text>{{isRecording ? '松开发送' : '按住说话'}}</text>
      </view>
      <view class="input-actions">
        <text class="action-btn image-btn" bindtap="onImageTap">📷</text>
      </view>
    </view>
  </view>
</view>