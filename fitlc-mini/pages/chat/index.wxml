<view class="chat-page">
  <!-- Messages -->
  <scroll-view
    class="messages-container"
    scroll-y
    scroll-top="{{scrollTop}}"
  >
    <view
      wx:for="{{messages}}"
      wx:key="id"
      class="message-item {{item.role}}"
    >
      <view class="message-avatar {{item.role}}">
        <image wx:if="{{item.role === 'user' && user.avatar}}" class="avatar-img" src="{{user.avatar}}" mode="aspectFill" />
        <image wx:elif="{{item.role === 'assistant'}}" class="avatar-img" src="/assets/logo.png" mode="aspectFill" />
        <text wx:else>{{item.role === 'user' ? '👤' : ''}}</text>
      </view>
      <view class="message-content {{item.role}}">
        <!-- 用户消息的图片 -->
        <view wx:if="{{item.imageUrls && item.imageUrls.length > 0}}" class="message-images">
          <image
            wx:for="{{item.imageUrls}}"
            wx:key="*this"
            src="{{item}}"
            mode="aspectFill"
            class="message-image"
          />
        </view>

        <!-- AI 消息 - 带工具数据，显示卡片 -->
        <view wx:if="{{item.role === 'assistant' && item.toolData}}" class="tool-card-wrapper">
          <workout-card wx:if="{{item.toolData.dataType === 'workout'}}" data="{{item.toolData.result}}" />
          <measurement-card wx:if="{{item.toolData.dataType === 'measurement'}}" data="{{item.toolData.result}}" />
          <workout-query-card wx:if="{{item.toolData.dataType === 'workout_query'}}" data="{{item.toolData.result}}" />
          <measurement-query-card wx:if="{{item.toolData.dataType === 'measurement_query'}}" data="{{item.toolData.result}}" />
          <plan-card wx:if="{{item.toolData.dataType === 'plan'}}" data="{{item.toolData.result}}" />
          <adjustment-card wx:if="{{item.toolData.dataType === 'plan_adjustment'}}" data="{{item.toolData.result}}" />
          <analysis-card wx:if="{{item.toolData.dataType === 'execution_analysis'}}" data="{{item.toolData.result}}" />
        </view>

        <!-- 需要补充信息的提示 -->
        <view wx:if="{{item.needsMoreInfo}}" class="needs-more-info">
          <text class="needs-more-icon">💡</text>
          <text class="needs-more-text">请补充信息后再次发送</text>
          <text wx:if="{{item.missingFields && item.missingFields.length > 0}}" class="missing-fields">
            需要：{{item.missingFields}}
          </text>
        </view>

        <!-- AI 回复文字 -->
        <text class="message-text" wx:if="{{item.role === 'assistant'}}">{{item.toolData ? item.toolData.aiReply : item.content}}</text>
        <text class="message-text" wx:else>{{item.content}}</text>

        <view wx:if="{{item.savedData}}" class="saved-indicator">
          <text>✓ 已保存</text>
          <text class="revoke-btn" data-id="{{item.id}}" bindtap="onMessageTap">撤销</text>
        </view>
        <text class="message-time">{{formatTime(item.createdAt)}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- Loading -->
  <view wx:if="{{isLoading}}" class="loading-indicator">
    <text>AI 处理中...</text>
  </view>

  <!-- Input Area -->
  <view class="input-area">
    <!-- 待发送图片预览 -->
    <view wx:if="{{pendingImages.length > 0}}" class="pending-images">
      <view wx:for="{{pendingImages}}" wx:key="*this" class="pending-image-item">
        <image src="{{item.path}}" mode="aspectFill" class="pending-image" />
        <text class="remove-btn" data-index="{{index}}" bindtap="onRemovePendingImage">×</text>
      </view>
    </view>

    <!-- 文字模式 -->
    <view wx:if="{{inputMode === 'text'}}" class="input-container">
      <text class="action-btn switch-btn" bindtap="onSwitchMode">🎤</text>
      <textarea
        class="chat-textarea"
        value="{{inputValue}}"
        placeholder="输入训练内容..."
        bindinput="onInput"
        auto-height
        maxlength="2000"
      />
      <view class="input-actions">
        <text class="action-btn image-btn" bindtap="onImageTap">📷</text>
        <text class="action-btn send-btn" bindtap="onSend">➤</text>
      </view>
    </view>

    <!-- 语音模式 -->
    <view wx:if="{{inputMode === 'voice'}}" class="input-container voice-mode">
      <text class="action-btn switch-btn" bindtap="onSwitchMode">⌨️</text>
      <view
        class="voice-hint {{isRecording ? 'recording' : ''}}"
        catchtouchstart="onVoiceTouchStart"
        catchtouchend="onVoiceTouchEnd"
      >
        <text>{{isRecording ? '松开发送' : '按住说话'}}</text>
      </view>
      <view class="input-actions">
        <text class="action-btn image-btn" bindtap="onImageTap">📷</text>
      </view>
    </view>
  </view>
</view>