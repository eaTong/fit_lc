.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
  background-color: var(--color-bg-primary);
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  background-color: var(--color-bg-tertiary);
  border-radius: 32rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: var(--color-accent);
  color: #fff;
  font-size: 32rpx;
  border-radius: 8px;
  border: none;
}

.wechat-login-btn::after {
  border: none;
}

.error-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--color-accent-red);
}

.agreement {
  margin-top: 48rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-align: center;
}

.link {
  color: var(--color-accent);
}