<view class="container">
  <!-- 时间筛选 -->
  <t-tabs
    value="{{filter}}"
    bind:change="onFilterChange"
    theme="card"
  >
    <t-tab-panel value="all" label="全部" />
    <t-tab-panel value="week" label="本周" />
    <t-tab-panel value="month" label="本月" />
  </t-tabs>

  <!-- 历史列表 -->
  <view class="history-content">
    <t-cell-group
      wx:if="{{filteredHistory.length > 0}}"
      theme="card"
    >
      <t-cell
        wx:for="{{filteredHistory}}"
        wx:key="id"
        title="{{item.durationText}}"
        description="使用 {{item.usedCount}} 次"
        note="{{item.dateText}}"
        hover
        data-id="{{item.id}}"
        bind:click="onItemTap"
        bind:longpress="onItemLongPress"
      />
    </t-cell-group>

    <t-empty
      wx:else
      icon="view-list"
      description="暂无记录"
    />
  </view>
</view>
