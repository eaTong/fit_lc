.settings-page {
  min-height: 100vh;
  background-color: var(--color-bg-primary);
  padding: 32rpx 0;
}

.avatar-value {
  display: flex;
  align-items: center;
}

.avatar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}
