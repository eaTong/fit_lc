.settings-page {
  min-height: 100vh;
  background-color: var(--color-bg-primary);
  padding: 32rpx;
}

.section {
  background-color: var(--color-bg-secondary);
  border-radius: 8px;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 24rpx 32rpx 16rpx;
  border-bottom: 1px solid var(--color-border);
}

.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1px solid var(--color-border);
}

.item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 32rpx;
  color: var(--color-text-primary);
}

.item-value {
  display: flex;
  align-items: center;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.item-value text {
  color: var(--color-text-secondary);
}

.arrow {
  margin-left: 16rpx;
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

.hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}