<view class="settings-page">
  <!-- Profile Section -->
  <view class="section">
    <view class="section-title">个人信息</view>
    <view class="item" bindtap="uploadAvatar">
      <text class="item-label">头像</text>
      <view class="item-value avatar-value">
        <image class="avatar-img" src="{{profile.avatar}}" wx:if="{{profile.avatar}}" />
        <text class="avatar-placeholder" wx:else>未设置</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="item" bindtap="editNickname">
      <text class="item-label">昵称</text>
      <view class="item-value">
        <text>{{profile.nickname || '未设置'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="item" bindtap="editGender">
      <text class="item-label">性别</text>
      <view class="item-value">
        <text>{{profile.gender === 'male' ? '男' : profile.gender === 'female' ? '女' : '未设置'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="item" bindtap="editHeight">
      <text class="item-label">身高</text>
      <view class="item-value">
        <text>{{profile.height ? profile.height + ' cm' : '未设置'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Metrics Section -->
  <view class="section">
    <view class="section-title">身体数据</view>
    <view class="item" bindtap="editWeight">
      <text class="item-label">体重</text>
      <view class="item-value">
        <text>{{latestMetrics.weight ? latestMetrics.weight + ' kg' : '未记录'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="item" bindtap="editBodyFat">
      <text class="item-label">体脂</text>
      <view class="item-value">
        <text>{{latestMetrics.bodyFat ? latestMetrics.bodyFat + ' %' : '未记录'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="item" bindtap="addMetric">
      <text class="item-label">添加记录</text>
      <view class="item-value">
        <text class="hint">记录今天的体重和体脂</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- History Section -->
  <view class="section">
    <view class="section-title">历史记录</view>
    <view class="item" bindtap="viewMetricsHistory">
      <text class="item-label">查看体重/体脂历史</text>
      <view class="item-value">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>