<view class="settings-page">
  <t-cell-group title="个人信息">
    <t-cell
      title="头像"
      arrow
      hover
      bind:click="uploadAvatar"
    >
      <view slot="note" class="avatar-value">
        <image
          wx:if="{{profile.avatar}}"
          class="avatar-img"
          src="{{profile.avatar}}"
          mode="aspectFill"
        />
        <text wx:else class="avatar-placeholder">未设置</text>
      </view>
    </t-cell>

    <t-cell
      title="昵称"
      description="{{profile.nickname || '未设置'}}"
      arrow
      hover
      bind:click="editNickname"
    />

    <t-cell
      title="性别"
      description="{{profile.gender === 'male' ? '男' : profile.gender === 'female' ? '女' : '未设置'}}"
      arrow
      hover
      bind:click="editGender"
    />

    <t-cell
      title="身高"
      description="{{profile.height ? profile.height + ' cm' : '未设置'}}"
      arrow
      hover
      bind:click="editHeight"
    />
  </t-cell-group>
</view>
