.container {
  min-height: 100vh;
  background-color: #0A0A0A;
  padding: 24rpx;
}

.filter-tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.filter-tab {
  font-size: 28rpx;
  color: #888888;
  padding: 12rpx 24rpx;
  border-radius: 4px;
  background-color: #1A1A1A;
}

.filter-tab.active {
  color: #FF4500;
  background-color: #252525;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  background-color: #1A1A1A;
  border-radius: 4px;
  padding: 24rpx;
}

.item-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.item-left {
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.item-stats {
  font-size: 28rpx;
  color: #888888;
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.item-date {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.item-duration {
  font-size: 24rpx;
  color: #888888;
}

.item-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4px;
  background-color: #252525;
  color: #888888;
}

.tag.unsynced {
  color: #FFA500;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
}