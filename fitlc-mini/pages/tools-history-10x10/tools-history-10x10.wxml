<view class="container">
  <!-- 时间筛选 -->
  <t-tabs
    value="{{filter}}"
    bind:change="onFilterChange"
    theme="card"
  >
    <t-tab-panel value="all" label="全部" />
    <t-tab-panel value="week" label="本周" />
    <t-tab-panel value="month" label="本月" />
  </t-tabs>

  <!-- 历史列表 -->
  <view class="history-content">
    <t-cell-group
      wx:if="{{filteredHistory.length > 0}}"
      theme="card"
    >
      <t-cell
        wx:for="{{filteredHistory}}"
        wx:key="id"
        title="{{item.exerciseName}}"
        description="{{item.sets}}组 / {{item.reps}}次"
        note="{{item.dateText}}"
        arrow
        hover
        data-id="{{item.id}}"
        data-action="tap"
        bind:click="onItemTap"
        bind:longpress="onItemLongPress"
      >
        <t-tag
          wx:if="{{item.savedToServer}}"
          slot="right-icon"
          theme="success"
          size="small"
          variant="light"
        >已同步</t-tag>
        <t-tag
          wx:else
          slot="right-icon"
          theme="warning"
          size="small"
          variant="light"
        >未同步</t-tag>
      </t-cell>
    </t-cell-group>

    <t-empty
      wx:else
      icon="view-list"
      description="暂无记录"
    />
  </view>
</view>
