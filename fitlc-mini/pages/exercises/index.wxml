<view class="exercises-page">
  <!-- Header with Filters -->
  <view class="exercises-header">
    <input
      class="search-input"
      placeholder="搜索动作..."
      value="{{searchKeyword}}"
      bindinput="onSearch"
    />
    <view class="filter-row">
      <view class="filter-group">
        <text class="filter-label">器械:</text>
        <text
          class="filter-tag {{filters.equipment === 'barbell' ? 'active' : ''}}"
          data-value="barbell"
          bindtap="onFilterEquipment"
        >杠铃</text>
        <text
          class="filter-tag {{filters.equipment === 'dumbbell' ? 'active' : ''}}"
          data-value="dumbbell"
          bindtap="onFilterEquipment"
        >哑铃</text>
        <text
          class="filter-tag {{filters.equipment === 'cable' ? 'active' : ''}}"
          data-value="cable"
          bindtap="onFilterEquipment"
        >绳索</text>
        <text
          class="filter-tag {{filters.equipment === 'machine' ? 'active' : ''}}"
          data-value="machine"
          bindtap="onFilterEquipment"
        >器械</text>
        <text
          class="filter-tag {{filters.equipment === 'bodyweight' ? 'active' : ''}}"
          data-value="bodyweight"
          bindtap="onFilterEquipment"
        >自重</text>
      </view>
      <view class="filter-group">
        <text class="filter-label">难度:</text>
        <text
          class="filter-tag {{filters.difficulty === 'beginner' ? 'active' : ''}}"
          data-value="beginner"
          bindtap="onFilterDifficulty"
        >初级</text>
        <text
          class="filter-tag {{filters.difficulty === 'intermediate' ? 'active' : ''}}"
          data-value="intermediate"
          bindtap="onFilterDifficulty"
        >中级</text>
        <text
          class="filter-tag {{filters.difficulty === 'advanced' ? 'active' : ''}}"
          data-value="advanced"
          bindtap="onFilterDifficulty"
        >高级</text>
      </view>
    </view>
  </view>

  <view class="main-content">
    <!-- Left Sidebar: Muscle Tree (48px wide) -->
    <view class="muscle-sidebar">
      <view
        class="muscle-item {{selectedMuscleId === null ? 'active' : ''}}"
        bindtap="onAllMuscles"
      >
        <text>全部</text>
      </view>
      <block wx:for="{{muscleHierarchy}}" wx:key="id">
        <view
          class="muscle-item {{selectedMuscleId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onMuscleSelect"
        >
          <text>{{item.name}}</text>
        </view>
        <!-- Children always shown when present -->
        <view wx:if="{{item.children}}" class="muscle-children">
          <view
            wx:for="{{item.children}}"
            wx:for-item="child"
            wx:key="id"
            class="muscle-item child {{selectedMuscleId === child.id ? 'active' : ''}}"
            data-id="{{child.id}}"
            bindtap="onMuscleSelect"
          >
            <text>{{child.name}}</text>
          </view>
        </view>
      </block>
    </view>

    <!-- Right Content: Muscle Info + Exercise List -->
    <view class="content-area">
      <!-- Muscle Info Card (always visible when muscle selected) -->
      <view wx:if="{{selectedMuscleInfo}}" class="muscle-info-card">
        <view class="muscle-info-header" bindtap="onMuscleToggle">
          <view class="muscle-title-row">
            <text class="muscle-name">{{selectedMuscleInfo.name}}</text>
            <text class="muscle-count">{{exercises.length}} 个动作</text>
          </view>
          <text class="toggle-icon {{muscleExpanded ? 'expanded' : ''}}">▼</text>
        </view>
        <!-- Always show function, expandable for more -->
        <view class="muscle-function {{muscleExpanded ? 'expanded' : ''}}">{{selectedMuscleInfo.function}}</view>
        <!-- Expandable details -->
        <view wx:if="{{muscleExpanded}}" class="muscle-details">
          <view wx:if="{{selectedMuscleInfo.origin}}" class="detail-row">
            <text class="detail-label">起点</text>
            <text class="detail-value">{{selectedMuscleInfo.origin}}</text>
          </view>
          <view wx:if="{{selectedMuscleInfo.insertion}}" class="detail-row">
            <text class="detail-label">止点</text>
            <text class="detail-value">{{selectedMuscleInfo.insertion}}</text>
          </view>
          <view wx:if="{{selectedMuscleInfo.trainingTips}}" class="detail-row">
            <text class="detail-label">训练技巧</text>
            <text class="detail-value">{{selectedMuscleInfo.trainingTips}}</text>
          </view>
        </view>
      </view>

      <!-- Exercise Grid -->
      <scroll-view class="exercise-list" scroll-y bindscrolltolower="onScrollToLower">
        <view class="exercise-list">
          <view
            wx:for="{{exercises}}"
            wx:key="id"
            class="exercise-item"
            data-id="{{item.id}}"
            bindtap="onExerciseTap"
          >
            <view class="exercise-info">
              <text class="exercise-name">{{item.name}}</text>
              <view class="exercise-tags">
                <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
            <text class="arrow">›</text>
          </view>
        </view>
        <view wx:if="{{loading}}" class="loading">加载中...</view>
        <view wx:if="{{loadingMore}}" class="loading-more">加载更多...</view>
        <view wx:if="{{!loading && !loadingMore && exercises.length === 0}}" class="empty">
          暂无动作
        </view>
        <view wx:if="{{!hasMore && exercises.length > 0}}" class="no-more">
          没有更多了
        </view>
      </scroll-view>
    </view>
  </view>
</view>