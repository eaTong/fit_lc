<view class="exercises-page">
  <!-- Header with Filters -->
  <view class="exercises-header">
    <t-search
      value="{{searchKeyword}}"
      placeholder="搜索动作..."
      bind:change="onSearch"
    />
    <view class="filter-row">
      <view class="filter-group">
        <text class="filter-label">器械:</text>
        <t-tag
          variant="light"
          theme="{{filters.equipment === 'barbell' ? 'primary' : 'default'}}"
          size="medium"
          checkable
          checked="{{filters.equipment === 'barbell'}}"
          data-value="barbell"
          bind:change="onFilterEquipment"
        >杠铃</t-tag>
        <t-tag
          variant="light"
          theme="{{filters.equipment === 'dumbbell' ? 'primary' : 'default'}}"
          size="medium"
          checkable
          checked="{{filters.equipment === 'dumbbell'}}"
          data-value="dumbbell"
          bind:change="onFilterEquipment"
        >哑铃</t-tag>
        <t-tag
          variant="light"
          theme="{{filters.equipment === 'cable' ? 'primary' : 'default'}}"
          size="medium"
          checkable
          checked="{{filters.equipment === 'cable'}}"
          data-value="cable"
          bind:change="onFilterEquipment"
        >绳索</t-tag>
        <t-tag
          variant="light"
          theme="{{filters.equipment === 'machine' ? 'primary' : 'default'}}"
          size="medium"
          checkable
          checked="{{filters.equipment === 'machine'}}"
          data-value="machine"
          bind:change="onFilterEquipment"
        >器械</t-tag>
        <t-tag
          variant="light"
          theme="{{filters.equipment === 'bodyweight' ? 'primary' : 'default'}}"
          size="medium"
          checkable
          checked="{{filters.equipment === 'bodyweight'}}"
          data-value="bodyweight"
          bind:change="onFilterEquipment"
        >自重</t-tag>
      </view>
      <view class="filter-group">
        <text class="filter-label">难度:</text>
        <t-tag
          variant="light"
          theme="{{filters.difficulty === 'beginner' ? 'primary' : 'default'}}"
          size="medium"
          checkable
          checked="{{filters.difficulty === 'beginner'}}"
          data-value="beginner"
          bind:change="onFilterDifficulty"
        >初级</t-tag>
        <t-tag
          variant="light"
          theme="{{filters.difficulty === 'intermediate' ? 'primary' : 'default'}}"
          size="medium"
          checkable
          checked="{{filters.difficulty === 'intermediate'}}"
          data-value="intermediate"
          bind:change="onFilterDifficulty"
        >中级</t-tag>
        <t-tag
          variant="light"
          theme="{{filters.difficulty === 'advanced' ? 'primary' : 'default'}}"
          size="medium"
          checkable
          checked="{{filters.difficulty === 'advanced'}}"
          data-value="advanced"
          bind:change="onFilterDifficulty"
        >高级</t-tag>
      </view>
    </view>
  </view>

  <view class="main-content">
    <!-- Left Sidebar: Muscle Tree (48px wide) -->
    <view class="muscle-sidebar">
      <view
        class="muscle-item {{selectedMuscleId === null ? 'active' : ''}}"
        bindtap="onAllMuscles"
      >
        <text>全部</text>
      </view>
      <block wx:for="{{muscleHierarchy}}" wx:key="id">
        <view
          class="muscle-item {{selectedMuscleId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onMuscleSelect"
        >
          <text>{{item.name}}</text>
        </view>
        <!-- Children always shown when present -->
        <view wx:if="{{item.children}}" class="muscle-children">
          <view
            wx:for="{{item.children}}"
            wx:for-item="child"
            wx:key="id"
            class="muscle-item child {{selectedMuscleId === child.id ? 'active' : ''}}"
            data-id="{{child.id}}"
            bindtap="onMuscleSelect"
          >
            <text>{{child.name}}</text>
          </view>
        </view>
      </block>
    </view>

    <!-- Right Content: Muscle Info + Exercise List -->
    <view class="content-area">
      <!-- Muscle Info Card (always visible when muscle selected) -->
      <view wx:if="{{selectedMuscleInfo}}" class="muscle-info-card">
        <view class="muscle-info-header" bindtap="onMuscleToggle">
          <view class="muscle-title-row">
            <text class="muscle-name">{{selectedMuscleInfo.name}}</text>
            <text class="muscle-count">{{exercises.length}} 个动作</text>
          </view>
          <text class="toggle-icon {{muscleExpanded ? 'expanded' : ''}}">▼</text>
        </view>
        <!-- Always show function, expandable for more -->
        <view class="muscle-function {{muscleExpanded ? 'expanded' : ''}}">{{selectedMuscleInfo.function}}</view>
        <!-- Expandable details -->
        <view wx:if="{{muscleExpanded}}" class="muscle-details">
          <view wx:if="{{selectedMuscleInfo.origin}}" class="detail-row">
            <text class="detail-label">起点</text>
            <text class="detail-value">{{selectedMuscleInfo.origin}}</text>
          </view>
          <view wx:if="{{selectedMuscleInfo.insertion}}" class="detail-row">
            <text class="detail-label">止点</text>
            <text class="detail-value">{{selectedMuscleInfo.insertion}}</text>
          </view>
          <view wx:if="{{selectedMuscleInfo.trainingTips}}" class="detail-row">
            <text class="detail-label">训练技巧</text>
            <text class="detail-value">{{selectedMuscleInfo.trainingTips}}</text>
          </view>
        </view>
      </view>

      <!-- Exercise Grid -->
      <scroll-view class="exercise-list" scroll-y bindscrolltolower="onScrollToLower">
        <view class="exercise-list">
          <view
            wx:for="{{exercises}}"
            wx:key="id"
            class="exercise-item"
            data-id="{{item.id}}"
            bindtap="onExerciseTap"
          >
            <view class="exercise-content">
              <text class="exercise-name">{{item.name}}</text>
              <view class="exercise-tags">
                <t-tag wx:for="{{item.tags}}" wx:key="*this" variant="light" size="small" theme="primary">{{item}}</t-tag>
              </view>
              <text class="exercise-desc">{{item.steps}}</text>
            </view>
            <text class="arrow">›</text>
          </view>
        </view>
        <t-loading wx:if="{{loading}}" theme="circular" size="medium" text="加载中..." />
        <t-loading wx:if="{{loadingMore}}" theme="circular" size="small" text="加载更多..." />
        <t-empty wx:if="{{!loading && !loadingMore && exercises.length === 0}}" icon="search" description="暂无动作" />
        <view wx:if="{{!hasMore && exercises.length > 0}}" class="no-more">
          没有更多了
        </view>
      </scroll-view>
    </view>
  </view>
</view>
