.exercises-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary);
}

.exercises-header {
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-secondary);
  border-bottom: 1px solid var(--color-border);
}

.search-bar {
  background-color: var(--color-bg-tertiary);
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
}

.search-input {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.header-actions {
  display: flex;
  justify-content: flex-end;
  gap: 32rpx;
}

.action-btn {
  font-size: 28rpx;
  color: var(--color-accent);
  padding: 8rpx 16rpx;
}

.muscle-tree {
  width: 200rpx;
  background-color: var(--color-bg-secondary);
  border-right: 1px solid var(--color-border);
  flex-shrink: 0;
  overflow-y: auto;
}

.muscle-item {
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  border-bottom: 1px solid var(--color-border);
}

.muscle-item.active {
  background-color: var(--color-bg-tertiary);
  color: var(--color-accent);
}

.muscle-item.child {
  padding-left: 48rpx;
  font-size: 24rpx;
}

.muscle-children {
  background-color: var(--color-bg-primary);
}

.exercise-list {
  flex: 1;
  padding: 24rpx;
}

.exercise-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.exercise-card {
  width: calc(50% - 12rpx);
  background-color: var(--color-bg-secondary);
  border-radius: 8px;
  padding: 24rpx;
  border: 1px solid var(--color-border);
}

.exercise-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.exercise-info {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background-color: var(--color-bg-tertiary);
  border-radius: 4px;
  color: var(--color-text-secondary);
}

.difficulty-beginner { color: #4CAF50; }
.difficulty-intermediate { color: #FF9800; }
.difficulty-advanced { color: #F44336; }

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}