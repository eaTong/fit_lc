.container {
  padding: 24rpx;
  background-color: #0A0A0A;
  min-height: 100vh;
}

.tools-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tool-card {
  display: flex;
  align-items: center;
  background-color: #1A1A1A;
  border-radius: 4px;
  padding: 32rpx;
  transition: background-color 150ms;
}

.tool-card:active {
  background-color: #252525;
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 24rpx;
}

.card-icon image {
  width: 100%;
  height: 100%;
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #888888;
}

.card-arrow {
  margin-left: 16rpx;
}

.arrow-text {
  font-size: 24rpx;
  color: #888888;
}