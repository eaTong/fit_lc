.container {
  min-height: 100vh;
  background-color: #0A0A0A;
  padding: 24rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.tab {
  font-size: 32rpx;
  color: #888888;
  padding-bottom: 8rpx;
}

.tab.active {
  color: #FFFFFF;
  border-bottom: 2px solid #FF4500;
}

.history-btn {
  font-size: 28rpx;
  color: #FF4500;
}

/* 配置阶段 */
.config {
  padding: 0 16rpx;
}

.form-item {
  display: flex;
  align-items: center;
  background-color: #1A1A1A;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: 4px;
}

.form-label {
  font-size: 28rpx;
  color: #888888;
  width: 160rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #FFFFFF;
  background: transparent;
  text-align: right;
}

.form-unit {
  font-size: 28rpx;
  color: #888888;
  margin-left: 8rpx;
}

.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #FFFFFF;
  text-align: right;
}

.start-btn {
  width: 100%;
  height: 120rpx;
  background-color: #FF4500;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  border-radius: 4px;
  margin-top: 40rpx;
}

.start-btn::after {
  border: none;
}

/* 计数阶段 */
.counting {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
}

.count-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.exercise-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.target-hint {
  font-size: 28rpx;
  color: #888888;
}

.count-display {
  margin-bottom: 40rpx;
}

.count-value {
  font-size: 200rpx;
  font-weight: bold;
  color: #FF4500;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background-color: #1A1A1A;
  border-radius: 8rpx;
  margin-bottom: 60rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #FF4500;
  transition: width 150ms;
}

.count-btn {
  width: 100%;
  height: 120rpx;
  background-color: #FF4500;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  border-radius: 4px;
}

.count-btn::after {
  border: none;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 24rpx;
  background-color: #0A0A0A;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 4px;
  border: 2px solid #FF4500;
}

.action-btn.pause,
.action-btn.resume {
  color: #FF4500;
}

.action-btn.end {
  color: #888888;
  border-color: #888888;
}

/* 完成阶段 */
.complete {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}

.summary {
  text-align: center;
  margin-bottom: 60rpx;
}

.summary-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 24rpx;
}

.summary-count {
  font-size: 32rpx;
  color: #888888;
}

.save-dialog {
  width: 100%;
  padding: 40rpx;
}

.dialog-buttons {
  display: flex;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  height: 100rpx;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 4px;
  border: none;
}

.dialog-btn.save {
  background-color: #FF4500;
  color: #FFFFFF;
}

.dialog-btn.cancel {
  background-color: transparent;
  color: #888888;
  border: 2px solid #888888;
}

.dialog-btn::after {
  border: none;
}

/* 暂停遮罩 */
.pause-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.pause-text {
  font-size: 64rpx;
  font-weight: bold;
  color: #FF4500;
}