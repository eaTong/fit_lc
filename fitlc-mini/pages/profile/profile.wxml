<view class="profile-page">
  <!-- User Info Section -->
  <view class="user-section">
    <view class="user-avatar">
      <image class="avatar-img" src="{{avatarUrl}}" wx:if="{{avatarUrl}}" />
      <text class="avatar-text" wx:else>{{avatarText}}</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{displayName}}</text>
      <view class="user-meta">
        <text class="user-gender" wx:if="{{gender}}">{{gender === 'male' ? '♂ 男' : '♀ 女'}}</text>
        <text class="user-email" wx:if="{{user.email}}">{{user.email}}</text>
      </view>
    </view>
    <view class="settings-btn" bindtap="goToSettings">
      <text>⚙️</text>
    </view>
  </view>

  <!-- Stats Row -->
  <view class="stats-row" wx:if="{{stats}}">
    <view class="stat-item">
      <text class="stat-value">{{stats.workoutCount || 0}}</text>
      <text class="stat-label">训练</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.totalVolume || '0T'}}</text>
      <text class="stat-label">容量</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.streak || 0}}</text>
      <text class="stat-label">连续</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.badgeCount || 0}}</text>
      <text class="stat-label">徽章</text>
    </view>
  </view>

  <!-- Body Metrics - Tappable -->
  <view class="metrics-section" bindtap="goToSettings">
    <view class="section-title">
      <text>身体数据</text>
      <text class="section-arrow">›</text>
    </view>
    <view class="metrics-row">
      <view class="metric-item">
        <text class="metric-label">身高</text>
        <text class="metric-value">{{height ? height + ' cm' : '--'}}</text>
      </view>
      <view class="metric-item">
        <text class="metric-label">体重</text>
        <text class="metric-value">{{weight ? weight + ' kg' : '--'}}</text>
      </view>
      <view class="metric-item">
        <text class="metric-label">体脂</text>
        <text class="metric-value {{bodyFatClass}}">{{bodyFat ? bodyFat + ' %' : '--'}}</text>
      </view>
      <view class="metric-item">
        <text class="metric-label">BMI</text>
        <text class="metric-value {{bmiClass}}">{{bmi || '--'}}</text>
      </view>
    </view>
  </view>

  <!-- Quick Access Grid -->
  <view class="quick-access">
    <view class="section-title">快捷入口</view>
    <t-grid col="{{5}}" border="{{false}}">
      <t-grid-item
        wx:for="{{quickAccess}}"
        wx:key="label"
        text="{{item.label}}"
        data-index="{{index}}"
        bind:click="onQuickAccess"
      >
        <view slot="image" class="quick-access-icon">{{item.icon}}</view>
      </t-grid-item>
    </t-grid>
  </view>

  <!-- Navigation List - using t-cell -->
  <t-cell-group>
    <t-cell title="关于作者" arrow hover bindtap="showAboutAuthor" />
  </t-cell-group>

  <!-- Logout Button -->
  <view class="logout-section">
    <t-button theme="danger" variant="outline" size="large" block bind:tap="onLogout">退出登录</t-button>
  </view>

  <!-- Toast -->
  <t-toast id="t-toast" />
</view>
