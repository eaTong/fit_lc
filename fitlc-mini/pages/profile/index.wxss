.profile-page {
  min-height: 100vh;
  background-color: var(--color-bg-primary);
  padding-bottom: 120rpx;
}

.user-section {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  background-color: var(--color-bg-secondary);
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  background-color: var(--color-accent);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.user-email {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.settings-btn {
  padding: 16rpx;
  font-size: 40rpx;
}

.stats-row {
  display: flex;
  padding: 32rpx;
  background-color: var(--color-bg-secondary);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-accent);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  padding: 24rpx 32rpx 16rpx;
}

.metrics-section {
  background-color: var(--color-bg-secondary);
  margin-top: 16rpx;
}

.metrics-row {
  display: flex;
  padding: 0 32rpx 24rpx;
  flex-wrap: wrap;
}

.metric-item {
  width: 22%;
  padding: 16rpx;
  background-color: var(--color-bg-tertiary);
  border-radius: 8px;
  margin-right: 4%;
  margin-bottom: 16rpx;
}

.metric-item:nth-child(4n) {
  margin-right: 0;
}

.metric-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 8rpx;
}

.metric-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.quick-access {
  margin-top: 16rpx;
}

.access-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
}

.access-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.access-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.access-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.logout-section {
  margin-top: 48rpx;
  padding: 0 32rpx;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: var(--color-bg-secondary);
  color: var(--color-text-secondary);
  font-size: 32rpx;
  border-radius: 8px;
  border: 1px solid var(--color-border);
}

.logout-btn::after {
  border: none;
}