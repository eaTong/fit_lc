/* pages/plans/index.wxss - Plans List Page Styles */

.page-container {
  min-height: 100vh;
  background-color: #0A0A0A;
  padding: 20rpx;
}

/* Page Header */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.create-btn {
  background-color: #FF4500;
  padding: 16rpx 28rpx;
  border-radius: 4rpx;
}

.create-btn-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

/* Tab Switcher */
.tab-switcher {
  display: flex;
  border-bottom: 2px solid #333333;
  margin: 0 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  right: 0;
  height: 2px;
  background-color: #FF4500;
}

.tab-label {
  font-size: 28rpx;
  color: #888888;
  font-weight: 600;
  text-transform: uppercase;
}

.tab-item.active .tab-label {
  color: #FF4500;
}

/* Loading */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  color: #888888;
  font-size: 28rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.empty-desc {
  color: #888888;
  font-size: 28rpx;
  margin-bottom: 50rpx;
}

.empty-btn {
  background-color: #FF4500;
  padding: 20rpx 60rpx;
  border-radius: 4rpx;
}

/* Plans List */
.plans-list {
  padding: 20rpx 0;
}

.plan-card {
  background-color: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 0 15px rgba(255, 69, 0, 0.1);
}

/* Card Header */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.plan-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.plan-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
}

.status-text {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
}

.arrow-icon {
  color: #888888;
  font-size: 40rpx;
}

/* Card Content */
.card-content {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1px solid #252525;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #888888;
  font-size: 26rpx;
}

.info-value {
  color: #FFFFFF;
  font-size: 26rpx;
}

/* Progress Section */
.progress-section {
  margin-top: 20rpx;
}

.progress-bar {
  height: 8rpx;
  background-color: #252525;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #FF4500;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  color: #888888;
  font-size: 24rpx;
  margin-top: 12rpx;
  text-align: right;
}