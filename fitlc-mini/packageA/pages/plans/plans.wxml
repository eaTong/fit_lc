<view class="page-container">
  <!-- Tab Switcher - using t-tabs -->
  <t-tabs value="{{activeTab}}" bind:change="onTabChange">
    <t-tab-panel wx:for="{{statusTabs}}" wx:key="id" label="{{item.label}}" value="{{item.id}}" />
  </t-tabs>

  <!-- Loading -->
  <t-loading wx:if="{{isLoading}}" theme="circular" size="medium" text="加载中..." />

  <!-- Empty State -->
  <t-empty wx:elif="{{filteredPlans.length === 0}}" icon="folder" description="暂无计划，开始创建你的第一个健身计划吧">
    <t-button slot="action" theme="primary" size="medium" bind:tap="onCreatePlan">生成新计划</t-button>
  </t-empty>

  <!-- Plan Cards -->
  <view wx:else class="plans-list">
    <view
      wx:for="{{filteredPlans}}"
      wx:key="id"
      class="plan-card"
      data-id="{{item.id}}"
      bindtap="goToPlanDetail"
    >
      <!-- Card Header -->
      <view class="card-header">
        <view class="plan-info">
          <text class="plan-name">{{item.name}}</text>
          <view class="status-badge" style="background-color: {{getStatusColor(item.status)}}">
            <text class="status-text">{{getStatusLabel(item.status)}}</text>
          </view>
        </view>
        <text class="arrow-icon">›</text>
      </view>

      <!-- Card Content -->
      <view class="card-content">
        <view class="info-row">
          <text class="info-label">目标</text>
          <text class="info-value">{{getGoalLabel(item.goal)}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">频率</text>
          <text class="info-value">每周{{item.frequency}}次</text>
        </view>
        <view class="info-row">
          <text class="info-label">周期</text>
          <text class="info-value">{{item.duration_weeks}}周</text>
        </view>
        <view class="info-row" wx:if="{{item.next_training_day}}">
          <text class="info-label">下一个训练日</text>
          <text class="info-value">{{formatDate(item.next_training_day)}}</text>
        </view>
      </view>

      <!-- Progress Bar -->
      <view class="progress-section">
        <view class="progress-bar">
          <view
            class="progress-fill"
            style="width: {{calculateProgress(item)}}%"
          ></view>
        </view>
        <text class="progress-text">已完成 {{calculateProgress(item)}}%</text>
      </view>
    </view>
  </view>
</view>
