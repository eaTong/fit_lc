/* pages/plan-detail/index.wxss - Plan Detail Page Styles */

.page-container {
  min-height: 100vh;
  background-color: #0A0A0A;
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* Loading */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 150rpx 0;
}

.loading-text {
  color: #888888;
  font-size: 28rpx;
}

/* Error */
.error-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 150rpx 0;
}

.error-text {
  color: #FF4500;
  font-size: 28rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.empty-desc {
  color: #888888;
  font-size: 28rpx;
}

/* Plan Content */
.plan-content {
  padding-bottom: 100rpx;
}

/* Plan Header Card */
.plan-header-card {
  background-color: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 0 15px rgba(255, 69, 0, 0.1);
}

.plan-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.plan-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  flex: 1;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 4rpx;
}

.status-text {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
}

.plan-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.meta-item {
  min-width: 130rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meta-label {
  color: #888888;
  font-size: 24rpx;
}

.meta-value {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

/* Plan Meta Grid */
.plan-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 20rpx;
}

/* Stats Card */
.stats-card {
  background-color: #1A1A1A;
  border: 2px solid #FF4500;
  border-radius: 8rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF4500;
}

.stat-label {
  font-size: 22rpx;
  color: #888888;
  margin-top: 8rpx;
}

/* Weekly Progress */
.weekly-progress {
  margin-top: 20rpx;
}

.progress-title {
  color: #888888;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  display: block;
}

.progress-bars {
  display: flex;
  gap: 12rpx;
}

.progress-day {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.day-name {
  color: #888888;
  font-size: 20rpx;
}

.progress-bar-container {
  width: 100%;
  height: 8rpx;
  background-color: #333333;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background-color: #FF4500;
  transition: width 0.3s;
}

.progress-bar-fill.completed {
  background-color: #4CAF50;
}

.progress-bar-fill.skipped {
  background-color: #FF9800;
}

.progress-bar-fill.rest {
  background-color: #666666;
}

.progress-bar-fill.in-progress {
  background-color: #FF4500;
}

.progress-bar-fill.pending {
  background-color: #333333;
}

.day-status {
  font-size: 20rpx;
  color: #888888;
}

/* Calendar Section */
.calendar-section {
  background-color: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 8rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-nav {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-btn {
  color: #FF4500;
  font-size: 32rpx;
  padding: 10rpx 20rpx;
}

.calendar-title {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

.calendar-grid {
  margin-bottom: 20rpx;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 16rpx;
}

.weekday {
  text-align: center;
  color: #888888;
  font-size: 24rpx;
  padding: 10rpx 0;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #252525;
  border-radius: 8rpx;
  position: relative;
}

.calendar-day.empty {
  background-color: transparent;
}

.calendar-day.today {
  border: 2px solid #FF4500;
}

.calendar-day.completed {
  background-color: rgba(76, 175, 80, 0.2);
}

.calendar-day.skipped {
  background-color: rgba(255, 152, 0, 0.2);
}

.calendar-day.rest {
  background-color: rgba(102, 102, 102, 0.2);
}

.day-number {
  color: #FFFFFF;
  font-size: 28rpx;
}

.day-icon {
  font-size: 18rpx;
  color: #888888;
}

.calendar-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #888888;
  font-size: 22rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot.completed {
  background-color: #4CAF50;
}

.dot.skipped {
  background-color: #FF9800;
}

.dot.rest {
  background-color: #666666;
}

/* Schedule Section */
.schedule-section {
  margin-top: 20rpx;
}

.section-title {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  display: block;
}

.week-days {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.day-card {
  background-color: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4rpx;
  padding: 24rpx;
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid #252525;
}

.day-label {
  color: #FF4500;
  font-size: 30rpx;
  font-weight: bold;
}

.exercise-count {
  color: #888888;
  font-size: 24rpx;
}

.exercise-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.exercise-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid #252525;
}

.exercise-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.exercise-name {
  color: #FFFFFF;
  font-size: 28rpx;
  flex: 1;
}

.exercise-info {
  color: #888888;
  font-size: 26rpx;
  background-color: #252525;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

/* Equipment Row */
.equipment-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
}

.equipment-row .meta-label {
  margin-bottom: 0;
  margin-right: 8rpx;
}

.equipment-tags {
  color: #FFFFFF;
  font-size: 24rpx;
}

/* Bottom Action */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #0A0A0A;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2px solid #333333;
}

.start-btn {
  background-color: #FF4500;
  padding: 24rpx 0;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20px rgba(255, 69, 0, 0.3);
}

.start-btn:active {
  background-color: #e03e00;
}

.start-btn-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}

/* Activate Button */
.activate-btn {
  background-color: #4CAF50;
  padding: 28rpx 0;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20px rgba(76, 175, 80, 0.3);
}

.activate-btn:active {
  background-color: #43a047;
}

.activate-btn-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}

/* Outline Button */
.outline-btn {
  background-color: transparent;
  border: 2px solid #333333;
  padding: 28rpx 0;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.outline-btn:active {
  border-color: #FF4500;
}

.outline-btn-text {
  color: #888888;
  font-size: 32rpx;
}