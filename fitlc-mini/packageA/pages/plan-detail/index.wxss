/* pages/plan-detail/index.wxss - Plan Detail Page Styles */

.page-container {
  min-height: 100vh;
  background-color: #0A0A0A;
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.title {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.placeholder {
  width: 60rpx;
}

/* Loading */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 150rpx 0;
}

.loading-text {
  color: #888888;
  font-size: 28rpx;
}

/* Error */
.error-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 150rpx 0;
}

.error-text {
  color: #FF4500;
  font-size: 28rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.empty-desc {
  color: #888888;
  font-size: 28rpx;
}

/* Plan Content */
.plan-content {
  padding-bottom: 100rpx;
}

/* Plan Header Card */
.plan-header-card {
  background-color: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 0 15px rgba(255, 69, 0, 0.1);
}

.plan-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.plan-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  flex: 1;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 4rpx;
}

.status-text {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
}

.plan-meta {
  display: flex;
  justify-content: space-between;
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meta-label {
  color: #888888;
  font-size: 24rpx;
}

.meta-value {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

/* Schedule Section */
.schedule-section {
  margin-top: 20rpx;
}

.section-title {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  display: block;
}

.week-days {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.day-card {
  background-color: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4rpx;
  padding: 24rpx;
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid #252525;
}

.day-label {
  color: #FF4500;
  font-size: 30rpx;
  font-weight: bold;
}

.exercise-count {
  color: #888888;
  font-size: 24rpx;
}

.exercise-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.exercise-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid #252525;
}

.exercise-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.exercise-name {
  color: #FFFFFF;
  font-size: 28rpx;
  flex: 1;
}

.exercise-info {
  color: #888888;
  font-size: 26rpx;
  background-color: #252525;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

/* Bottom Action */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #0A0A0A;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2px solid #333333;
}

.start-btn {
  background-color: #FF4500;
  padding: 24rpx 0;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20px rgba(255, 69, 0, 0.3);
}

.start-btn:active {
  background-color: #e03e00;
}

.start-btn-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}