<view class="page-container">
  <!-- Progress Indicator -->
  <t-steps
    current="{{currentStep - 1}}"
    theme="default"
  >
    <t-step-item title="目标" />
    <t-step-item title="训练" />
    <t-step-item title="身体数据" />
  </t-steps>

  <!-- Step 1: Goal & Cycle -->
  <view class="step-content" wx:if="{{currentStep === 1}}">
    <view class="step-title">选择您的训练目标</view>

    <!-- Goal Selection -->
    <t-grid col="{{3}}" border="{{false}}">
      <t-grid-item
        wx:for="{{goalOptions}}"
        wx:key="value"
        text="{{item.label}}"
        data-value="{{item.value}}"
        bind:click="onGoalSelect"
      >
        <view slot="image" class="goal-icon">{{item.icon}}</view>
        <view slot="description" class="goal-desc">{{item.desc}}</view>
      </t-grid-item>
    </t-grid>

    <view class="step-title" style="margin-top: 40rpx;">计划周期</view>
    <view class="cycle-row">
      <t-check-tag
        wx:for="{{cycleOptions}}"
        wx:key="*this"
        checked="{{formData.duration_weeks === item}}"
        data-weeks="{{item}}"
        bind:click="onCycleSelect"
      >{{item}}周</t-check-tag>
    </view>

    <view class="bottom-btn">
      <t-button theme="primary" size="large" block bind:tap="onStep1Next">下一步 →</t-button>
    </view>
  </view>

  <!-- Step 2: Frequency & Equipment -->
  <view class="step-content" wx:if="{{currentStep === 2}}">
    <view class="step-title">每周训练几次？</view>
    <t-picker
      value="{{[formData.frequency - 2]}}"
      data-key="frequency"
      bind:change="onPickerChange"
    >
      <view class="picker-box">
        <text>{{formData.frequency}}天/周</text>
        <text class="picker-arrow">›</text>
      </view>
    </t-picker>

    <view class="step-title" style="margin-top: 40rpx;">可用器械（多选）</view>
    <view class="equipment-grid">
      <t-check-tag
        wx:for="{{equipmentOptions}}"
        wx:key="*this"
        checked="{{isEquipmentSelected(item)}}"
        data-eq="{{item}}"
        bind:click="onEquipmentToggle"
      >{{item}}</t-check-tag>
    </view>

    <view class="step-title" style="margin-top: 40rpx;">训练经验</view>
    <t-radio-group
      value="{{formData.experience}}"
      bind:change="onExperienceChange"
    >
      <view class="experience-row">
        <t-radio
          wx:for="{{experienceOptions}}"
          wx:key="value"
          value="{{item.value}}"
          label="{{item.label}}"
        />
      </view>
    </t-radio-group>

    <view class="bottom-btns">
      <t-button theme="default" variant="outline" block bind:tap="onStep2Back">← 上一步</t-button>
      <t-button theme="primary" block bind:tap="onStep2Next">下一步 →</t-button>
    </view>
  </view>

  <!-- Step 3: Body Data -->
  <view class="step-content" wx:if="{{currentStep === 3}}">
    <view class="step-title">基本身体数据（帮助计算合适的重量）</view>

    <view class="input-row">
      <view class="input-item">
        <t-input
          label="身高 (cm)"
          type="number"
          placeholder="175"
          value="{{formData.height}}"
          data-key="height"
          bind:change="onFormInput"
        />
      </view>
      <view class="input-item">
        <t-input
          label="体重 (kg)"
          type="number"
          placeholder="70"
          value="{{formData.body_weight}}"
          data-key="body_weight"
          bind:change="onFormInput"
        />
      </view>
    </view>

    <view class="step-subtitle">体脂率（可选）</view>
    <t-input
      type="digit"
      placeholder="18.5"
      value="{{formData.body_fat}}"
      data-key="body_fat"
      bind:change="onFormInput"
    />

    <view class="step-subtitle">伤病/身体状况（可选）</view>
    <t-textarea
      placeholder="如有伤病或身体状况请在此说明"
      value="{{formData.conditions}}"
      data-key="conditions"
      bind:change="onFormInput"
    />

    <view class="bottom-btns">
      <t-button theme="default" variant="outline" block bind:tap="onStep3Back">← 上一步</t-button>
      <t-button
        theme="primary"
        block
        loading="{{isLoading}}"
        disabled="{{isLoading}}"
        bind:tap="onSubmit"
      >{{isLoading ? '生成中...' : '生成计划'}}</t-button>
    </view>
  </view>

  <!-- Error Message -->
  <view wx:if="{{error}}" class="error-text">
    <text>{{error}}</text>
  </view>
</view>
