/* pages/plan-generate/plan-generate.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg-primary);
  padding: 20rpx;
}

.step-content {
  padding: 20rpx;
}

.step-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 30rpx;
}

.step-subtitle {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  margin-top: 24rpx;
}

.goal-icon {
  font-size: 48rpx;
  line-height: 1;
}

.goal-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.cycle-row {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.picker-box {
  background-color: var(--color-bg-secondary);
  border: 2rpx solid var(--color-border);
  border-radius: 4rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: var(--color-text-primary);
  font-size: 28rpx;
}

.picker-arrow {
  color: var(--color-text-secondary);
  font-size: 36rpx;
}

.equipment-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.experience-row {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background-color: var(--color-bg-secondary);
  border-radius: 4rpx;
  padding: 20rpx;
  border: 2rpx solid var(--color-border);
}

.input-row {
  display: flex;
  gap: 20rpx;
}

.input-item {
  flex: 1;
}

.bottom-btn {
  margin-top: 60rpx;
}

.bottom-btns {
  margin-top: 60rpx;
  display: flex;
  gap: 20rpx;
}

.bottom-btns .t-button {
  flex: 1;
}

.error-text {
  color: var(--color-accent);
  font-size: 28rpx;
  text-align: center;
  padding: 20rpx 0;
  margin-top: 20rpx;
}
