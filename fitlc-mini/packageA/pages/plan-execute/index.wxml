<view class="page-container">
  <!-- Loading -->
  <view wx:if="{{isLoading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Error -->
  <view wx:elif="{{error}}" class="error-container">
    <text class="error-text">{{error}}</text>
  </view>

  <!-- Execution Content -->
  <view wx:elif="{{plan}}" class="execution-content">
    <!-- Progress Ring Section -->
    <view class="progress-ring-section">
      <canvas canvas-id="progressRing" class="progress-ring-canvas"></canvas>
      <view class="progress-ring-center">
        <text class="progress-count">{{completedCount}}/{{totalCount}}</text>
        <text class="progress-label">完成</text>
      </view>
    </view>

    <!-- Date Card -->
    <view class="date-card">
      <text class="date-label">{{getTodayLabel()}}</text>
      <text class="date-value">{{executionDate}}</text>
    </view>

    <!-- Plan Name -->
    <view class="plan-name-card">
      <text class="plan-name">{{plan.name}}</text>
    </view>

    <!-- Exercises List -->
    <view class="exercises-section">
      <text class="section-title">训练动作</text>

      <view class="exercise-cards">
        <view
          wx:for="{{exercises}}"
          wx:for-item="exercise"
          wx:key="id"
          class="exercise-card"
        >
          <!-- Exercise Header -->
          <view class="exercise-header">
            <text class="exercise-name">{{exercise.name}}</text>
            <text class="exercise-target">{{exercise.targetSets}}组 x {{exercise.targetReps}}次</text>
          </view>

          <!-- Sets Table -->
          <view class="sets-table">
            <view class="sets-header">
              <text class="col-set">组数</text>
              <text class="col-weight">重量(kg)</text>
              <text class="col-reps">次数</text>
              <text class="col-status">完成</text>
            </view>

            <view
              wx:for="{{exercise.sets}}"
              wx:for-item="setItem"
              wx:key="setIndex"
              class="set-row"
            >
              <text class="col-set">{{setItem.setIndex}}</text>
              <input
                class="col-weight input-field"
                type="digit"
                placeholder="0"
                value="{{setItem.weight}}"
                data-exercise-index="{{index}}"
                data-set-index="{{setItem.setIndex - 1}}"
                bindchange="onSetWeightChange"
              />
              <input
                class="col-reps input-field"
                type="number"
                placeholder="0"
                value="{{setItem.reps}}"
                data-exercise-index="{{index}}"
                data-set-index="{{setItem.setIndex - 1}}"
                bindchange="onSetRepsChange"
              />
              <checkbox
                class="col-status checkbox"
                value="{{setItem.completed}}"
                checked="{{setItem.completed}}"
                data-exercise-index="{{index}}"
                data-set-index="{{setItem.setIndex - 1}}"
                bindchange="onSetCompletedChange"
              />
            </view>
          </view>

          <!-- Exercise Actions -->
          <view class="exercise-actions">
            <text class="edit-btn" bindtap="onEditExercise" data-index="{{index}}">编辑重量/次数</text>
          </view>

          <!-- Exercise Notes -->
          <view class="exercise-notes">
            <text class="notes-label">备注</text>
            <input
              class="notes-input"
              type="text"
              placeholder="添加备注..."
              value="{{exercise.exerciseNotes}}"
              data-exercise-index="{{index}}"
              bindchange="onExerciseNotesChange"
            />
          </view>
        </view>
      </view>
    </view>

    <!-- Empty State -->
    <view wx:if="{{exercises.length === 0}}" class="empty-state">
      <text class="empty-icon">🏋️</text>
      <text class="empty-title">今日无训练安排</text>
      <text class="empty-desc">该计划今日没有分配训练动作</text>
    </view>
  </view>

  <!-- Bottom Action -->
  <view wx:if="{{plan && !isLoading}}" class="bottom-action">
    <view
      class="checkin-btn {{isSubmitting ? 'disabled' : ''}}"
      bindtap="onCompleteCheckin"
    >
      <text wx:if="{{!isSubmitting}}" class="checkin-btn-text">完成打卡</text>
      <text wx:if="{{isSubmitting}}" class="checkin-btn-text">提交中...</text>
    </view>
  </view>

  <!-- Exercise Editor Modal -->
  <view wx:if="{{showEditModal}}" class="modal-mask" bindtap="onCloseEditModal">
    <view class="modal-content" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">编辑动作 - {{editingExercise.name}}</text>
      </view>

      <view class="modal-body">
        <!-- Sets Selector -->
        <view class="edit-row">
          <text class="edit-label">组数</text>
          <view class="sets-selector">
            <text
              wx:for="{{[3, 4, 5, 6]}}"
              wx:key="*this"
              class="sets-option {{editingExercise.tempSets === item ? 'selected' : ''}}"
              data-sets="{{item}}"
              bindtap="onSelectSets"
            >{{item}}</text>
          </view>
        </view>

        <!-- Reps Input -->
        <view class="edit-row">
          <text class="edit-label">每组次数</text>
          <input
            class="edit-input"
            type="number"
            placeholder="如 8-12"
            value="{{editingExercise.tempReps}}"
            bindinput="onEditRepsInput"
          />
        </view>

        <!-- Weight Input -->
        <view class="edit-row">
          <text class="edit-label">重量 (kg)</text>
          <input
            class="edit-input"
            type="digit"
            placeholder="如 60"
            value="{{editingExercise.tempWeight}}"
            bindinput="onEditWeightInput"
          />
        </view>
      </view>

      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="onCloseEditModal">取消</button>
        <button class="modal-btn confirm" bindtap="onConfirmEdit">确认完成</button>
      </view>
    </view>
  </view>
</view>