/* pages/plan-execute/index.wxss - Plan Execute Page Styles */

.page-container {
  min-height: 100vh;
  background-color: #0A0A0A;
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* Loading */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 150rpx 0;
}

.loading-text {
  color: #888888;
  font-size: 28rpx;
}

/* Error */
.error-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 150rpx 0;
}

.error-text {
  color: #FF4500;
  font-size: 28rpx;
}

/* Execution Content */
.execution-content {
  padding-bottom: 100rpx;
}

/* Date Card */
.date-card {
  background-color: #1A1A1A;
  border: 2px solid #FF4500;
  border-radius: 4rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 0 15px rgba(255, 69, 0, 0.2);
}

.date-label {
  color: #FF4500;
  font-size: 30rpx;
  font-weight: bold;
}

.date-value {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
}

/* Plan Name Card */
.plan-name-card {
  background-color: #252525;
  border: 2px solid #333333;
  border-radius: 4rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 30rpx;
}

.plan-name {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
}

/* Exercises Section */
.exercises-section {
  margin-top: 20rpx;
}

.section-title {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  display: block;
}

.exercise-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Exercise Card */
.exercise-card {
  background-color: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4rpx;
  padding: 24rpx;
}

.exercise-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid #252525;
}

.exercise-name {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: bold;
  flex: 1;
}

.exercise-target {
  color: #FF4500;
  font-size: 26rpx;
  background-color: #252525;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

/* Sets Table */
.sets-table {
  margin-bottom: 20rpx;
}

.sets-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1px solid #333333;
  margin-bottom: 8rpx;
}

.sets-header text {
  color: #888888;
  font-size: 24rpx;
  text-align: center;
}

.set-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1px solid #252525;
}

.set-row:last-child {
  border-bottom: none;
}

.set-row text {
  color: #FFFFFF;
  font-size: 28rpx;
  text-align: center;
}

.col-set {
  width: 60rpx;
}

.col-weight {
  flex: 1;
  margin: 0 8rpx;
}

.col-reps {
  flex: 1;
  margin: 0 8rpx;
}

.col-status {
  width: 80rpx;
  display: flex;
  justify-content: center;
}

.input-field {
  background-color: #252525;
  border: 1px solid #333333;
  border-radius: 4rpx;
  padding: 12rpx 8rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  text-align: center;
  margin: 0 8rpx;
}

.checkbox {
  transform: scale(0.8);
}

/* Exercise Notes */
.exercise-notes {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid #252525;
}

.notes-label {
  color: #888888;
  font-size: 26rpx;
}

.notes-input {
  flex: 1;
  background-color: #252525;
  border: 1px solid #333333;
  border-radius: 4rpx;
  padding: 12rpx 16rpx;
  color: #FFFFFF;
  font-size: 28rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.empty-desc {
  color: #888888;
  font-size: 28rpx;
}

/* Bottom Action */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #0A0A0A;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2px solid #333333;
}

.checkin-btn {
  background-color: #FF4500;
  padding: 24rpx 0;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20px rgba(255, 69, 0, 0.3);
}

.checkin-btn.disabled {
  background-color: #666666;
  box-shadow: none;
}

.checkin-btn:active:not(.disabled) {
  background-color: #e03e00;
}

.checkin-btn-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}