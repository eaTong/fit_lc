/* pages/plan-execute/plan-execute.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg-primary);
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* Loading */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 150rpx 0;
}

/* Error */
.error-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 150rpx 0;
}

.error-text {
  color: var(--color-accent);
  font-size: 28rpx;
}

.execution-content {
  padding-bottom: 100rpx;
}

/* Progress Ring Section */
.progress-ring-section {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
  position: relative;
}

.progress-ring-canvas {
  width: 160px;
  height: 160px;
}

.progress-ring-center {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.progress-count {
  color: var(--color-text-primary);
  font-size: 36rpx;
  font-weight: bold;
}

.progress-label {
  color: var(--color-text-secondary);
  font-size: 24rpx;
  margin-top: 4rpx;
}

/* Date Card */
.date-card {
  background-color: var(--color-bg-secondary);
  border: 2rpx solid var(--color-accent);
  border-radius: 4rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 0 15px rgba(255, 69, 0, 0.2);
}

.date-label {
  color: var(--color-accent);
  font-size: 30rpx;
  font-weight: bold;
}

.date-value {
  color: var(--color-text-primary);
  font-size: 32rpx;
  font-weight: 600;
}

/* Plan Name Card */
.plan-name-card {
  background-color: var(--color-bg-tertiary);
  border: 2rpx solid var(--color-border);
  border-radius: 4rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 30rpx;
}

.plan-name {
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: 600;
}

.exercises-section {
  margin-top: 20rpx;
}

.section-title {
  color: var(--color-text-primary);
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  display: block;
}

.exercise-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.exercise-card {
  background-color: var(--color-bg-secondary);
  border: 2rpx solid var(--color-border);
  border-radius: 4rpx;
  padding: 24rpx;
}

.exercise-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--color-bg-tertiary);
}

.exercise-name {
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: bold;
  flex: 1;
}

/* Sets Table */
.sets-table {
  margin-bottom: 20rpx;
}

.sets-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 2rpx solid var(--color-border);
  margin-bottom: 8rpx;
}

.sets-header text {
  color: var(--color-text-secondary);
  font-size: 24rpx;
  text-align: center;
}

.set-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 2rpx solid var(--color-bg-tertiary);
}

.set-row:last-child {
  border-bottom: none;
}

.set-row text {
  color: var(--color-text-primary);
  font-size: 28rpx;
  text-align: center;
}

.col-set {
  width: 60rpx;
}

.col-weight {
  flex: 1;
  margin: 0 8rpx;
}

.col-reps {
  flex: 1;
  margin: 0 8rpx;
}

.col-status {
  width: 80rpx;
  display: flex;
  justify-content: center;
}

.input-field {
  background-color: var(--color-bg-tertiary);
  border: 2rpx solid var(--color-border);
  border-radius: 4rpx;
  padding: 12rpx 8rpx;
  color: var(--color-text-primary);
  font-size: 28rpx;
  text-align: center;
  margin: 0 8rpx;
}

/* Exercise Actions */
.exercise-actions {
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--color-bg-tertiary);
  margin-bottom: 16rpx;
}

.edit-btn {
  color: var(--color-accent);
  font-size: 26rpx;
  text-align: right;
}

.exercise-notes {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 16rpx;
}

.notes-label {
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.notes-input {
  flex: 1;
  background-color: var(--color-bg-tertiary);
  border: 2rpx solid var(--color-border);
  border-radius: 4rpx;
  padding: 12rpx 16rpx;
  color: var(--color-text-primary);
  font-size: 28rpx;
}

/* Bottom Action */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--color-bg-primary);
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid var(--color-border);
}

/* Dialog content */
.dialog-content {
  padding: 16rpx 0;
}

.edit-row {
  margin-bottom: 30rpx;
}

.edit-label {
  color: var(--color-text-secondary);
  font-size: 28rpx;
  margin-bottom: 16rpx;
  display: block;
}

.sets-selector {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
