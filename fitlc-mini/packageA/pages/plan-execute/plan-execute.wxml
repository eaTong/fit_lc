<view class="page-container">
  <!-- Loading -->
  <view wx:if="{{isLoading}}" class="loading-container">
    <t-loading theme="circular" size="40rpx" loading />
  </view>

  <!-- Error -->
  <view wx:elif="{{error}}" class="error-container">
    <text class="error-text">{{error}}</text>
  </view>

  <!-- Execution Content -->
  <view wx:elif="{{plan}}" class="execution-content">
    <!-- Progress Ring Section -->
    <view class="progress-ring-section">
      <canvas canvas-id="progressRing" class="progress-ring-canvas" style="width:160px;height:160px;"></canvas>
      <view class="progress-ring-center">
        <text class="progress-count">{{completedCount}}/{{totalCount}}</text>
        <text class="progress-label">完成</text>
      </view>
    </view>

    <!-- Date Card -->
    <view class="date-card">
      <text class="date-label">{{getTodayLabel()}}</text>
      <text class="date-value">{{executionDate}}</text>
    </view>

    <!-- Plan Name -->
    <view class="plan-name-card">
      <text class="plan-name">{{plan.name}}</text>
    </view>

    <!-- Exercises List -->
    <view class="exercises-section">
      <text class="section-title">训练动作</text>

      <view class="exercise-cards">
        <view
          wx:for="{{exercises}}"
          wx:for-item="exercise"
          wx:key="id"
          class="exercise-card"
        >
          <!-- Exercise Header -->
          <view class="exercise-header">
            <text class="exercise-name">{{exercise.name}}</text>
            <t-tag theme="primary" size="small" variant="light">{{exercise.targetSets}}组 x {{exercise.targetReps}}次</t-tag>
          </view>

          <!-- Sets Table -->
          <view class="sets-table">
            <view class="sets-header">
              <text class="col-set">组数</text>
              <text class="col-weight">重量(kg)</text>
              <text class="col-reps">次数</text>
              <text class="col-status">完成</text>
            </view>

            <view
              wx:for="{{exercise.sets}}"
              wx:for-item="setItem"
              wx:key="setIndex"
              class="set-row"
            >
              <text class="col-set">{{setItem.setIndex}}</text>
              <input
                class="col-weight input-field"
                type="digit"
                placeholder="0"
                value="{{setItem.weight}}"
                data-exercise-index="{{index}}"
                data-set-index="{{setItem.setIndex - 1}}"
                bindchange="onSetWeightChange"
              />
              <input
                class="col-reps input-field"
                type="number"
                placeholder="0"
                value="{{setItem.reps}}"
                data-exercise-index="{{index}}"
                data-set-index="{{setItem.setIndex - 1}}"
                bindchange="onSetRepsChange"
              />
              <view class="col-status">
                <t-checkbox
                  value="{{setItem.completed}}"
                  checked="{{setItem.completed}}"
                  data-exercise-index="{{index}}"
                  data-set-index="{{setItem.setIndex - 1}}"
                  bind:change="onSetCompletedChange"
                />
              </view>
            </view>
          </view>

          <!-- Exercise Actions -->
          <view class="exercise-actions">
            <text class="edit-btn" bindtap="onEditExercise" data-index="{{index}}">编辑重量/次数</text>
          </view>

          <!-- Exercise Notes -->
          <view class="exercise-notes">
            <text class="notes-label">备注</text>
            <input
              class="notes-input"
              type="text"
              placeholder="添加备注..."
              value="{{exercise.exerciseNotes}}"
              data-exercise-index="{{index}}"
              bindchange="onExerciseNotesChange"
            />
          </view>
        </view>
      </view>
    </view>

    <!-- Empty State -->
    <t-empty
      wx:if="{{exercises.length === 0}}"
      icon="info-circle"
      description="该计划今日没有分配训练动作"
    />
  </view>

  <!-- Bottom Action -->
  <view wx:if="{{plan && !isLoading}}" class="bottom-action">
    <t-button
      theme="primary"
      size="large"
      block
      loading="{{isSubmitting}}"
      disabled="{{isSubmitting}}"
      bind:tap="onCompleteCheckin"
    >{{isSubmitting ? '提交中...' : '完成打卡'}}</t-button>
  </view>

  <!-- Exercise Editor Dialog -->
  <t-dialog
    visible="{{showEditModal}}"
    title="编辑动作 - {{editingExercise.name}}"
    confirm-btn="确认完成"
    cancel-btn="取消"
    bind:close="onCloseEditModal"
    bind:confirm="onConfirmEdit"
  >
    <view class="dialog-content">
      <view class="edit-row">
        <text class="edit-label">组数</text>
        <view class="sets-selector">
          <t-check-tag
            wx:for="{{[3, 4, 5, 6]}}"
            wx:key="*this"
            checked="{{editingExercise.tempSets === item}}"
            data-sets="{{item}}"
            bind:click="onSelectSets"
          >{{item}}</t-check-tag>
        </view>
      </view>

      <view class="edit-row">
        <text class="edit-label">每组次数</text>
        <t-input
          type="number"
          placeholder="如 8-12"
          value="{{editingExercise.tempReps}}"
          bind:change="onEditRepsInput"
        />
      </view>

      <view class="edit-row">
        <text class="edit-label">重量 (kg)</text>
        <t-input
          type="digit"
          placeholder="如 60"
          value="{{editingExercise.tempWeight}}"
          bind:change="onEditWeightInput"
        />
      </view>
    </view>
  </t-dialog>
</view>
