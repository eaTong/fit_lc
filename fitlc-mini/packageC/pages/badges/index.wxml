<view class="badges-page">
  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Empty State -->
  <view wx:elif="{{isEmpty}}" class="empty-container">
    <text class="empty-icon">🏅</text>
    <text class="empty-text">暂无徽章</text>
    <text class="empty-hint">完成训练和记录围度来获取徽章吧</text>
  </view>

  <!-- Badges Grid -->
  <scroll-view
    wx:else
    class="badges-container"
    scroll-y
    enable-back-to-top
    bindscrolltoupper="onRefresh"
    upper-threshold="50"
  >
    <view class="badges-grid">
      <view
        wx:for="{{badges}}"
        wx:key="id"
        class="badge-card {{item.earned ? 'earned' : 'locked'}}"
      >
        <view class="badge-icon">
          <text>{{item.icon}}</text>
        </view>
        <view class="badge-info">
          <text class="badge-name">{{item.name}}</text>
          <text class="badge-date" wx:if="{{item.earned}}">{{formatDate(item.earnedAt)}}</text>
          <text class="badge-condition" wx:else>{{item.condition}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>