<view class="badges-page">
  <!-- Header -->
  <view class="badges-header">
    <text class="header-title">成就徽章</text>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Badges by Category -->
  <scroll-view
    wx:else
    class="badges-container"
    scroll-y
    enable-back-to-top
    bindscrolltoupper="onRefresh"
    upper-threshold="50"
  >
    <block wx:for="{{categoryList}}" wx:for-key="category" wx:for-item="categoryData">
      <view class="category-section">
        <view class="category-header">
          <text class="category-name">{{categoryData.name}}</text>
          <text class="category-count">{{categoryData.earnedCount}}/{{categoryData.badges.length}}</text>
        </view>
        <view class="badges-grid">
          <view
            wx:for="{{categoryData.badges}}"
            wx:for-key="id"
            wx:for-item="badge"
            class="badge-card {{badge.earned ? 'earned' : 'locked'}} tier-{{badge.tier}}"
            data-badge="{{badge}}"
            bindtap="onBadgeTap"
          >
            <view class="badge-icon-wrap">
              <image
                class="badge-icon"
                src="{{badge.iconUrl}}"
                mode="aspectFit"
                lazy-load
              />
            </view>
            <view class="badge-info">
              <text class="badge-name">{{badge.name}}</text>
              <text class="badge-date" wx:if="{{badge.earned}}">{{formatDate(badge.achievedAt)}}</text>
              <text class="badge-condition" wx:else>{{badge.points}}积分</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- Stats Footer -->
    <view class="stats-footer">
      <text class="stats-text">已获得 {{earnedCount}} / {{totalCount}} 徽章</text>
    </view>
  </scroll-view>
</view>