.badges-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary, #0A0A0A);
}

.badges-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary, #FFFFFF);
}

/* Loading */
.loading-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
}

/* Badges Container */
.badges-container {
  flex: 1;
  padding: 24rpx;
}

/* Category Section */
.category-section {
  margin-bottom: 32rpx;
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  border-bottom: 1px solid var(--color-border, #333333);
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
}

.category-count {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
}

/* Badges Grid - 3 columns */
.badges-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

/* Badge Card */
.badge-card {
  width: 32%;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-radius: 8rpx;
  padding: 20rpx 12rpx;
  margin-bottom: 20rpx;
  border: 2px solid var(--color-border, #333333);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* Earned state */
.badge-card.earned {
  background-color: #1A1A1A;
}

/* Locked state */
.badge-card.locked {
  opacity: 0.75;
}

/* Tier colors for earned badges */
.badge-card.tier-bronze.earned {
  border-color: #CD7F32;
}

.badge-card.tier-silver.earned {
  border-color: #C0C0C0;
}

.badge-card.tier-gold.earned {
  border-color: #FFD700;
}

.badge-card.tier-platinum.earned {
  border-color: #E5E4E2;
}

.badge-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 12rpx;
}

.badge-icon {
  width: 100rpx;
  height: 100rpx;
}

.badge-card.locked .badge-icon {
  opacity: 0.4;
}

.badge-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.badge-name {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
  text-align: center;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.badge-card.locked .badge-name {
  color: var(--color-text-secondary, #888888);
}

.badge-date {
  font-size: 18rpx;
  color: #FFD700;
  text-align: center;
}

.badge-condition {
  font-size: 18rpx;
  color: var(--color-text-secondary, #888888);
  text-align: center;
}

/* Stats Footer */
.stats-footer {
  padding: 24rpx 0;
  text-align: center;
  border-top: 1px solid var(--color-border, #333333);
  margin-top: 16rpx;
}

.stats-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
}