<view class="gallery-page">
  <!-- Upload Button -->
  <view class="upload-section">
    <button
      class="upload-btn"
      bindtap="onUploadTap"
      disabled="{{uploading}}"
    >
      {{uploading ? '上传中...' : '上传照片'}}
    </button>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Empty State -->
  <view wx:elif="{{isEmpty}}" class="empty-container">
    <text class="empty-icon">🖼️</text>
    <text class="empty-text">暂无照片</text>
    <text class="empty-hint">点击上方按钮上传照片</text>
  </view>

  <!-- Photo Grid -->
  <scroll-view
    wx:else
    class="content-container"
    scroll-y
    enable-back-to-top
    bindscrolltoupper="onRefresh"
    bindscrolltolower="onScrollToLower"
    lower-threshold="100"
    upper-threshold="50"
  >
    <!-- Grouped by Month -->
    <block wx:for="{{Object.keys(groupedPhotos)}}" wx:for-key="monthKey" wx:for-item="monthKey">
      <view class="month-group">
        <text class="month-label">{{monthKey}}</text>
        <view class="photo-grid">
          <view
            wx:for="{{groupedPhotos[monthKey]}}"
            wx:for-key="photo.id"
            wx:for-item="photo"
            class="photo-item"
            data-photo="{{photo}}"
            bindtap="onPhotoTap"
            bindlongpress="onPhotoLongPress"
          >
            <image
              class="photo-image"
              src="{{photo.ossUrl || photo.url}}"
              mode="aspectFill"
              lazy-load
            />
          </view>
        </view>
      </view>
    </block>

    <!-- Load More -->
    <view class="load-more">
      <text wx:if="{{loadingMore}}" class="loading-more-text">加载更多...</text>
      <text wx:elif="{{!hasMore}}" class="no-more-text">没有更多照片了</text>
    </view>
  </scroll-view>
</view>