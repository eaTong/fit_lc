.gallery-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary, #0A0A0A);
}

/* Upload Section */
.upload-section {
  padding: 16rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.upload-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #FF4500;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 8rpx;
  border: none;
}

.upload-btn[disabled] {
  background-color: #666666;
}

/* Loading */
.loading-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
}

/* Empty State */
.empty-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-secondary, #888888);
}

/* Content Container */
.content-container {
  flex: 1;
  padding: 16rpx 24rpx;
}

/* Month Group */
.month-group {
  margin-bottom: 32rpx;
}

.month-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary, #888888);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* Photo Grid - 3 columns */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.photo-item {
  width: calc(33.33% - 8rpx);
  aspect-ratio: 1;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-radius: 4rpx;
  overflow: hidden;
  border: 1px solid var(--color-border, #333333);
}

.photo-image {
  width: 100%;
  height: 100%;
}

/* Load More */
.load-more {
  padding: 32rpx 0;
  text-align: center;
}

.loading-more-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
}

.no-more-text {
  font-size: 24rpx;
  color: var(--color-text-muted, #555555);
}