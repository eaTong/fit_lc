.measurements-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary, #0A0A0A);
}

.page-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary, #FFFFFF);
}

/* Loading */
.loading-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
}

/* Empty State */
.empty-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-secondary, #888888);
}

/* Content Container */
.content-container {
  flex: 1;
  padding: 16rpx 24rpx;
}

/* Latest Card */
.latest-card {
  background-color: var(--color-bg-secondary, #1A1A1A);
  border: 1px solid var(--color-border, #333333);
  border-radius: 4rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.latest-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.latest-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-accent, #FF4500);
}

.latest-date {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
}

.latest-detail-date {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
  margin-bottom: 24rpx;
}

/* Measurements Grid */
.measurements-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.measurement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  padding: 16rpx;
  background-color: var(--color-bg-tertiary, #252525);
  border-radius: 4rpx;
  flex: 1;
  max-width: calc(33.33% - 16rpx);
}

.item-label {
  font-size: 22rpx;
  color: var(--color-text-secondary, #888888);
  margin-bottom: 8rpx;
}

.item-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary, #FFFFFF);
}

.item-unit {
  font-size: 20rpx;
  color: var(--color-text-secondary, #888888);
  margin-top: 4rpx;
}

/* Other Items */
.other-items {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid var(--color-border, #333333);
}

.other-items-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
  margin-right: 8rpx;
}

.other-items-value {
  font-size: 24rpx;
  color: var(--color-text-primary, #FFFFFF);
}

/* History Section */
.history-section {
  margin-top: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 16rpx;
  display: block;
}

/* History Item */
.history-item {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-radius: 4rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  border: 1px solid var(--color-border, #333333);
}

.history-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: var(--color-bg-tertiary, #252525);
  border-radius: 4rpx;
  font-size: 36rpx;
  flex-shrink: 0;
}

.history-content {
  flex: 1;
  margin-left: 16rpx;
  overflow: hidden;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.history-date {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
}

.history-detail-date {
  font-size: 22rpx;
  color: var(--color-text-secondary, #888888);
}

.history-parts {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-arrow {
  width: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--color-text-secondary, #888888);
  font-size: 28rpx;
}

/* Tab Container */
.tab-container {
  display: flex;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
}

.tab-item.active {
  border-bottom: 4rpx solid var(--color-accent, #FF4500);
}

.tab-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
}

.tab-item.active .tab-text {
  color: var(--color-accent, #FF4500);
  font-weight: 600;
}

/* Date Range Selector */
.date-range-selector {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 0;
  justify-content: center;
}

.range-btn {
  padding: 12rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border: 1px solid var(--color-border, #333333);
  border-radius: 4rpx;
}

.range-btn.active {
  background-color: var(--color-accent, #FF4500);
  border-color: var(--color-accent, #FF4500);
}

.range-btn text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #888888);
}

.range-btn.active text {
  color: #FFFFFF;
}

/* Chart Section */
.chart-section {
  background-color: var(--color-bg-secondary, #1A1A1A);
  border: 1px solid var(--color-border, #333333);
  border-radius: 4rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 16rpx;
  display: block;
}

.chart-container {
  height: 400rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.chart-empty {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.chart-empty text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #888888);
}