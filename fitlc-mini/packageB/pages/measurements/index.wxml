<view class="measurements-page">
  <!-- Tab Switcher -->
  <view class="tab-container">
    <view
      class="tab-item {{activeTab === 'list' ? 'active' : ''}}"
      data-tab="list"
      bindtap="onTabChange"
    >
      <text class="tab-text">记录</text>
    </view>
    <view
      class="tab-item {{activeTab === 'trend' ? 'active' : ''}}"
      data-tab="trend"
      bindtap="onTabChange"
    >
      <text class="tab-text">趋势</text>
    </view>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Empty State -->
  <view wx:elif="{{isEmpty}}" class="empty-container">
    <text class="empty-icon">📏</text>
    <text class="empty-text">暂无围度记录</text>
    <text class="empty-hint">去聊天页记录你的第一条围度吧</text>
  </view>

  <!-- List Tab Content -->
  <scroll-view
    wx:if="{{activeTab === 'list'}}"
    class="content-container"
    scroll-y
    enable-back-to-top
    bindscrolltoupper="onRefresh"
    upper-threshold="50"
  >
    <!-- Latest Measurement Card - always show for inline editing -->
    <view class="latest-card">
      <view class="latest-header">
        <text class="latest-label">最新记录</text>
        <text class="latest-date">{{latestMeasurement && latestMeasurement.date ? formatDate(latestMeasurement.date) : '暂无记录'}}</text>
      </view>
      <view class="latest-detail-date">{{latestMeasurement && latestMeasurement.date ? formatDetailDate(latestMeasurement.date) : ''}}</view>

      <view class="measurements-grid">
        <!-- 第一行：独立部位 -->
        <view class="grid-row">
          <view class="measurement-cell {{latestMeasurement.weight ? 'filled' : 'empty'}}" bindtap="onCellTap" data-part="weight">
            <text class="cell-label">体重</text>
            <text class="cell-value">{{latestMeasurement.weight || ''}}</text>
            <text class="cell-unit">{{latestMeasurement.weight ? 'kg' : ''}}</text>
          </view>
          <view class="measurement-cell {{latestMeasurement.chest ? 'filled' : 'empty'}}" bindtap="onCellTap" data-part="chest">
            <text class="cell-label">胸围</text>
            <text class="cell-value">{{latestMeasurement.chest || ''}}</text>
            <text class="cell-unit">{{latestMeasurement.chest ? 'cm' : ''}}</text>
          </view>
          <view class="measurement-cell {{latestMeasurement.waist ? 'filled' : 'empty'}}" bindtap="onCellTap" data-part="waist">
            <text class="cell-label">腰围</text>
            <text class="cell-value">{{latestMeasurement.waist || ''}}</text>
            <text class="cell-unit">{{latestMeasurement.waist ? 'cm' : ''}}</text>
          </view>
          <view class="measurement-cell {{latestMeasurement.hips ? 'filled' : 'empty'}}" bindtap="onCellTap" data-part="hips">
            <text class="cell-label">臀围</text>
            <text class="cell-value">{{latestMeasurement.hips || ''}}</text>
            <text class="cell-unit">{{latestMeasurement.hips ? 'cm' : ''}}</text>
          </view>
        </view>

        <!-- 第二行：对称部位 -->
        <view class="grid-row symmetrical">
          <view class="measurement-cell half {{latestMeasurement.biceps_l ? 'filled' : 'empty'}}" bindtap="onCellTap" data-part="biceps_l">
            <text class="cell-label">左臂围</text>
            <text class="cell-value">{{latestMeasurement.biceps_l || ''}}</text>
            <text class="cell-unit">{{latestMeasurement.biceps_l ? 'cm' : ''}}</text>
          </view>
          <view class="measurement-cell half {{latestMeasurement.biceps_r ? 'filled' : 'empty'}}" bindtap="onCellTap" data-part="biceps_r">
            <text class="cell-label">右臂围</text>
            <text class="cell-value">{{latestMeasurement.biceps_r || ''}}</text>
            <text class="cell-unit">{{latestMeasurement.biceps_r ? 'cm' : ''}}</text>
          </view>
          <view class="measurement-cell half {{latestMeasurement.thigh_l ? 'filled' : 'empty'}}" bindtap="onCellTap" data-part="thigh_l">
            <text class="cell-label">左腿围</text>
            <text class="cell-value">{{latestMeasurement.thigh_l || ''}}</text>
            <text class="cell-unit">{{latestMeasurement.thigh_l ? 'cm' : ''}}</text>
          </view>
          <view class="measurement-cell half {{latestMeasurement.thigh_r ? 'filled' : 'empty'}}" bindtap="onCellTap" data-part="thigh_r">
            <text class="cell-label">右腿围</text>
            <text class="cell-value">{{latestMeasurement.thigh_r || ''}}</text>
            <text class="cell-unit">{{latestMeasurement.thigh_r ? 'cm' : ''}}</text>
          </view>
          <view class="measurement-cell half {{latestMeasurement.calf_l ? 'filled' : 'empty'}}" bindtap="onCellTap" data-part="calf_l">
            <text class="cell-label">左小腿</text>
            <text class="cell-value">{{latestMeasurement.calf_l || ''}}</text>
            <text class="cell-unit">{{latestMeasurement.calf_l ? 'cm' : ''}}</text>
          </view>
          <view class="measurement-cell half {{latestMeasurement.calf_r ? 'filled' : 'empty'}}" bindtap="onCellTap" data-part="calf_r">
            <text class="cell-label">右小腿</text>
            <text class="cell-value">{{latestMeasurement.calf_r || ''}}</text>
            <text class="cell-unit">{{latestMeasurement.calf_r ? 'cm' : ''}}</text>
          </view>
        </view>
      </view>

      <!-- Other Items -->
      <view wx:if="{{latestMeasurement.items && latestMeasurement.items.length > 0}}" class="other-items">
        <text class="other-items-label">其他部位：</text>
        <text class="other-items-value">{{getMeasurementParts(latestMeasurement)}}</text>
      </view>
    </view>

    <!-- History Section -->
    <view class="history-section">
      <text class="section-title">历史记录</text>

      <view
        wx:for="{{measurements}}"
        wx:key="id"
        class="history-item"
        data-measurement="{{item}}"
        bindtap="onMeasurementTap"
      >
        <view class="history-icon">
          <text>📏</text>
        </view>
        <view class="history-content">
          <view class="history-header">
            <text class="history-date">{{formatDate(item.date)}}</text>
            <text class="history-detail-date">{{formatDetailDate(item.date)}}</text>
          </view>
          <text class="history-parts">{{getMeasurementParts(item)}}</text>
        </view>
        <view class="history-arrow">
          <text>></text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Trend Tab Content -->
  <scroll-view
    wx:elif="{{activeTab === 'trend'}}"
    class="content-container"
    scroll-y
  >
    <!-- Date Range Selector -->
    <view class="date-range-selector">
      <view
        class="range-btn {{dateRange === '30' ? 'active' : ''}}"
        data-range="30"
        bindtap="onDateRangeChange"
      >
        <text>30天</text>
      </view>
      <view
        class="range-btn {{dateRange === '90' ? 'active' : ''}}"
        data-range="90"
        bindtap="onDateRangeChange"
      >
        <text>90天</text>
      </view>
      <view
        class="range-btn {{dateRange === '365' ? 'active' : ''}}"
        data-range="365"
        bindtap="onDateRangeChange"
      >
        <text>1年</text>
      </view>
    </view>

    <!-- Measurement Trend Chart -->
    <view class="chart-section">
      <text class="chart-title">围度记录趋势</text>
      <view class="chart-container">
        <ec-canvas wx:if="{{measurementTrendData.categories.length > 0}}" canvas-id="measurement-trend" ec="{{ measurementTrendEc }}"></ec-canvas>
        <view wx:else class="chart-empty">
          <text>暂无趋势数据</text>
        </view>
      </view>
    </view>

    <!-- Workout Frequency Chart -->
    <view class="chart-section">
      <text class="chart-title">每周训练次数</text>
      <view class="chart-container">
        <ec-canvas wx:if="{{workoutTrendData.categories.length > 0}}" canvas-id="workout-trend" ec="{{ workoutTrendEc }}"></ec-canvas>
        <view wx:else class="chart-empty">
          <text>暂无训练数据</text>
        </view>
      </view>
    </view>

    <!-- Muscle Volume Pie Chart -->
    <view class="chart-section">
      <text class="chart-title">肌肉训练容量</text>
      <view class="chart-container">
        <ec-canvas wx:if="{{musclePieData.length > 0}}" canvas-id="muscle-pie" ec="{{ musclePieEc }}"></ec-canvas>
        <view wx:else class="chart-empty">
          <text>暂无训练数据</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 输入弹窗 -->
  <view class="input-modal {{showInputModal ? 'show' : ''}}" bindtap="onModalTap">
    <view class="input-panel" catchtap="noop">
      <text class="input-title">{{inputTargetPartName}}</text>
      <input class="input-field" type="digit" value="{{inputValue}}" bindinput="onInputChange" placeholder="请输入数值" />
      <text class="input-unit">{{inputTargetUnit}}</text>
      <view class="input-actions">
        <button class="btn-cancel" bindtap="onInputCancel">取消</button>
        <button class="btn-confirm" bindtap="onInputConfirm">确认</button>
      </view>
    </view>
  </view>
</view>