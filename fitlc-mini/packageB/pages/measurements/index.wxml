<view class="measurements-page">
  <!-- Tab Switcher -->
  <view class="tab-container">
    <view
      class="tab-item {{activeTab === 'list' ? 'active' : ''}}"
      data-tab="list"
      bindtap="onTabChange"
    >
      <text class="tab-text">记录</text>
    </view>
    <view
      class="tab-item {{activeTab === 'trend' ? 'active' : ''}}"
      data-tab="trend"
      bindtap="onTabChange"
    >
      <text class="tab-text">趋势</text>
    </view>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Empty State -->
  <view wx:elif="{{isEmpty}}" class="empty-container">
    <text class="empty-icon">📏</text>
    <text class="empty-text">暂无围度记录</text>
    <text class="empty-hint">去聊天页记录你的第一条围度吧</text>
  </view>

  <!-- List Tab Content -->
  <scroll-view
    wx:elif="{{activeTab === 'list'}}"
    class="content-container"
    scroll-y
    enable-back-to-top
    bindscrolltoupper="onRefresh"
    upper-threshold="50"
  >
    <!-- Latest Measurement Card -->
    <view wx:if="{{latestMeasurement}}" class="latest-card">
      <view class="latest-header">
        <text class="latest-label">最新记录</text>
        <text class="latest-date">{{formatDate(latestMeasurement.date)}}</text>
      </view>
      <view class="latest-detail-date">{{formatDetailDate(latestMeasurement.date)}}</view>

      <view class="measurements-grid">
        <!-- Weight -->
        <view class="measurement-item" wx:if="{{latestMeasurement.weight}}">
          <text class="item-label">体重</text>
          <text class="item-value">{{latestMeasurement.weight}}</text>
          <text class="item-unit">kg</text>
        </view>

        <!-- Chest -->
        <view class="measurement-item" wx:if="{{latestMeasurement.chest}}">
          <text class="item-label">胸围</text>
          <text class="item-value">{{latestMeasurement.chest}}</text>
          <text class="item-unit">cm</text>
        </view>

        <!-- Waist -->
        <view class="measurement-item" wx:if="{{latestMeasurement.waist}}">
          <text class="item-label">腰围</text>
          <text class="item-value">{{latestMeasurement.waist}}</text>
          <text class="item-unit">cm</text>
        </view>

        <!-- Hips -->
        <view class="measurement-item" wx:if="{{latestMeasurement.hips}}">
          <text class="item-label">臀围</text>
          <text class="item-value">{{latestMeasurement.hips}}</text>
          <text class="item-unit">cm</text>
        </view>

        <!-- Arm -->
        <view class="measurement-item" wx:if="{{latestMeasurement.arm}}">
          <text class="item-label">臂围</text>
          <text class="item-value">{{latestMeasurement.arm}}</text>
          <text class="item-unit">cm</text>
        </view>

        <!-- Thigh -->
        <view class="measurement-item" wx:if="{{latestMeasurement.thigh}}">
          <text class="item-label">腿围</text>
          <text class="item-value">{{latestMeasurement.thigh}}</text>
          <text class="item-unit">cm</text>
        </view>
      </view>

      <!-- Other Items -->
      <view wx:if="{{latestMeasurement.items && latestMeasurement.items.length > 0}}" class="other-items">
        <text class="other-items-label">其他部位：</text>
        <text class="other-items-value">{{getMeasurementParts(latestMeasurement)}}</text>
      </view>
    </view>

    <!-- History Section -->
    <view class="history-section">
      <text class="section-title">历史记录</text>

      <view
        wx:for="{{measurements}}"
        wx:key="id"
        class="history-item"
        data-measurement="{{item}}"
        bindtap="onMeasurementTap"
      >
        <view class="history-icon">
          <text>📏</text>
        </view>
        <view class="history-content">
          <view class="history-header">
            <text class="history-date">{{formatDate(item.date)}}</text>
            <text class="history-detail-date">{{formatDetailDate(item.date)}}</text>
          </view>
          <text class="history-parts">{{getMeasurementParts(item)}}</text>
        </view>
        <view class="history-arrow">
          <text>></text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Trend Tab Content -->
  <scroll-view
    wx:elif="{{activeTab === 'trend'}}"
    class="content-container"
    scroll-y
  >
    <!-- Date Range Selector -->
    <view class="date-range-selector">
      <view
        class="range-btn {{dateRange === '30' ? 'active' : ''}}"
        data-range="30"
        bindtap="onDateRangeChange"
      >
        <text>30天</text>
      </view>
      <view
        class="range-btn {{dateRange === '90' ? 'active' : ''}}"
        data-range="90"
        bindtap="onDateRangeChange"
      >
        <text>90天</text>
      </view>
      <view
        class="range-btn {{dateRange === '365' ? 'active' : ''}}"
        data-range="365"
        bindtap="onDateRangeChange"
      >
        <text>1年</text>
      </view>
    </view>

    <!-- Measurement Trend Chart -->
    <view class="chart-section">
      <text class="chart-title">围度记录趋势</text>
      <view class="chart-container">
        <ec-canvas wx:if="{{measurementTrendData.categories.length > 0}}" canvas-id="measurement-trend" ec="{{ measurementTrendEc }}"></ec-canvas>
        <view wx:else class="chart-empty">
          <text>暂无趋势数据</text>
        </view>
      </view>
    </view>

    <!-- Workout Frequency Chart -->
    <view class="chart-section">
      <text class="chart-title">每周训练次数</text>
      <view class="chart-container">
        <ec-canvas wx:if="{{workoutTrendData.categories.length > 0}}" canvas-id="workout-trend" ec="{{ workoutTrendEc }}"></ec-canvas>
        <view wx:else class="chart-empty">
          <text>暂无训练数据</text>
        </view>
      </view>
    </view>

    <!-- Muscle Volume Pie Chart -->
    <view class="chart-section">
      <text class="chart-title">肌肉训练容量</text>
      <view class="chart-container">
        <ec-canvas wx:if="{{musclePieData.length > 0}}" canvas-id="muscle-pie" ec="{{ musclePieEc }}"></ec-canvas>
        <view wx:else class="chart-empty">
          <text>暂无训练数据</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>