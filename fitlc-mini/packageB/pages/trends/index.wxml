<view class="trends-page">
  <!-- Tab Switcher: 围度趋势 / 训练趋势 -->
  <view class="tab-container">
    <view
      class="tab-item {{activeTab === 'measurement' ? 'active' : ''}}"
      data-tab="measurement"
      bindtap="onTabChange"
    >
      <text class="tab-text">围度趋势</text>
    </view>
    <view
      class="tab-item {{activeTab === 'workout' ? 'active' : ''}}"
      data-tab="workout"
      bindtap="onTabChange"
    >
      <text class="tab-text">训练趋势</text>
    </view>
  </view>

  <!-- Date Range Selector -->
  <view class="date-range-container">
    <view
      class="date-range-item {{dateRange === '30' ? 'active' : ''}}"
      data-range="30"
      bindtap="onDateRangeChange"
    >
      <text class="date-range-text">30天</text>
    </view>
    <view
      class="date-range-item {{dateRange === '90' ? 'active' : ''}}"
      data-range="90"
      bindtap="onDateRangeChange"
    >
      <text class="date-range-text">90天</text>
    </view>
    <view
      class="date-range-item {{dateRange === '365' ? 'active' : ''}}"
      data-range="365"
      bindtap="onDateRangeChange"
    >
      <text class="date-range-text">1年</text>
    </view>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Content -->
  <scroll-view
    wx:else
    class="content-container"
    scroll-y
    enable-back-to-top
  >
    <!-- 围度趋势 Tab -->
    <block wx:if="{{activeTab === 'measurement'}}">
      <view class="chart-card">
        <text class="chart-title">围度记录趋势</text>
        <view class="chart-wrapper">
          <ec-canvas
            wx:if="{{measurementTrendData.option}}"
            canvas-id="measurement-chart"
            ec="{{measurementTrendData}}"
          />
          <view wx:else class="chart-empty">
            <text class="empty-text">暂无数据</text>
          </view>
        </view>
      </view>

      <!-- 肌肉容量饼图 -->
      <view class="chart-card">
        <text class="chart-title">肌肉训练容量</text>
        <view class="chart-wrapper">
          <ec-canvas
            wx:if="{{musclePieOption}}"
            canvas-id="muscle-pie-chart"
            ec="{{musclePieOption}}"
          />
          <view wx:else class="chart-empty">
            <text class="empty-text">暂无数据</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 训练趋势 Tab -->
    <block wx:if="{{activeTab === 'workout'}}">
      <view class="chart-card">
        <text class="chart-title">每周训练次数</text>
        <view class="chart-wrapper">
          <ec-canvas
            wx:if="{{workoutTrendData.option}}"
            canvas-id="workout-chart"
            ec="{{workoutTrendData}}"
          />
          <view wx:else class="chart-empty">
            <text class="empty-text">暂无数据</text>
          </view>
        </view>
      </view>

      <!-- 肌肉容量饼图 -->
      <view class="chart-card">
        <text class="chart-title">肌肉训练容量</text>
        <view class="chart-wrapper">
          <ec-canvas
            wx:if="{{musclePieOption}}"
            canvas-id="muscle-pie-chart-2"
            ec="{{musclePieOption}}"
          />
          <view wx:else class="chart-empty">
            <text class="empty-text">暂无数据</text>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- Refresh Button -->
  <view class="refresh-btn" bindtap="onRefresh">
    <text class="refresh-icon">↻</text>
  </view>
</view>