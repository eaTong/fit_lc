.trends-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary, #0A0A0A);
}

.trends-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary, #FFFFFF);
}

/* Tab Container */
.tab-container {
  display: flex;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
  transition: color 0.15s ease;
}

.tab-item.active .tab-text {
  color: var(--color-accent, #FF4500);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background-color: var(--color-accent, #FF4500);
  border-radius: 2rpx;
}

/* Date Range Selector */
.date-range-container {
  display: flex;
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.date-range-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12rpx 0;
  margin: 0 8rpx;
  border: 1px solid var(--color-border, #333333);
  border-radius: 4rpx;
  background-color: var(--color-bg-tertiary, #252525);
  transition: all 0.15s ease;
}

.date-range-item.active {
  background-color: var(--color-accent, #FF4500);
  border-color: var(--color-accent, #FF4500);
}

.date-range-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #888888);
}

.date-range-item.active .date-range-text {
  color: #FFFFFF;
  font-weight: 600;
}

/* Loading */
.loading-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
}

/* Content Container */
.content-container {
  flex: 1;
  padding: 24rpx;
}

/* Chart Card */
.chart-card {
  background-color: var(--color-bg-secondary, #1A1A1A);
  border: 1px solid var(--color-border, #333333);
  border-radius: 4rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.chart-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 20rpx;
}

.chart-wrapper {
  width: 100%;
  height: 400rpx;
  position: relative;
}

.chart-empty {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: var(--color-bg-tertiary, #252525);
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
}

/* Refresh Button */
.refresh-btn {
  position: fixed;
  right: 32rpx;
  bottom: 100rpx;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: var(--color-accent, #FF4500);
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(255, 69, 0, 0.4);
}

.refresh-icon {
  font-size: 40rpx;
  color: #FFFFFF;
}