.calendar-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary, #0A0A0A);
}

/* Header */
.calendar-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary, #FFFFFF);
}

/* Month Navigator */
.month-navigator {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: var(--color-bg-tertiary, #252525);
  border-radius: 4rpx;
}

.nav-arrow {
  font-size: 32rpx;
  color: var(--color-text-primary, #FFFFFF);
  font-weight: 600;
}

.month-label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
}

/* Weekday Header */
.weekday-header {
  display: flex;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.weekday-cell {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0;
}

.weekday-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
}

/* Calendar Grid */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 16rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
}

.day-cell {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 12rpx 0;
  position: relative;
}

.day-cell.empty {
  height: 80rpx;
}

.day-cell:not(.empty):active {
  background-color: var(--color-bg-tertiary, #252525);
}

.day-text {
  font-size: 28rpx;
  color: var(--color-text-primary, #FFFFFF);
  height: 40rpx;
  line-height: 40rpx;
}

.day-cell.today .day-text {
  color: var(--color-accent, #FF4500);
  font-weight: 700;
}

.day-cell.selected .day-text {
  color: var(--color-accent, #FF4500);
  font-weight: 700;
}

.day-cell.selected::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: var(--color-accent, #FF4500);
  border-radius: 2rpx;
}

/* Record Dots */
.record-dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 4rpx;
  height: 16rpx;
  margin-top: 4rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.dot-workout {
  background-color: var(--color-accent, #FF4500);
}

.dot-measurement {
  background-color: #00CED1;
}

/* Legend */
.legend {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48rpx;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-top: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
}

/* Detail Overlay */
.detail-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 100;
}

.detail-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 60vh;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-top: 1px solid var(--color-border, #333333);
  border-radius: 16rpx 16rpx 0 0;
  display: flex;
  flex-direction: column;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.detail-date {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
}

.detail-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: var(--color-bg-tertiary, #252525);
  border-radius: 4rpx;
}

.detail-close text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
}

.detail-empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 64rpx 0;
}

.detail-empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
}

.detail-records {
  flex: 1;
  padding: 16rpx 24rpx;
  max-height: 400rpx;
}

.detail-record {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-tertiary, #252525);
  border-radius: 4rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.detail-record:active {
  opacity: 0.8;
}

.record-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-radius: 4rpx;
  font-size: 32rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
  margin-left: 16rpx;
  overflow: hidden;
}

.record-type {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 4rpx;
}

.record-summary {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 2rpx;
}

.record-detail {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary, #888888);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-arrow {
  width: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--color-text-secondary, #888888);
  font-size: 24rpx;
}

/* Records Section (All Records List) */
.records-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary, #0A0A0A);
  min-height: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
}

.record-count {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888888);
}

.records-list {
  flex: 1;
  padding: 0 24rpx 24rpx;
}

.record-item {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.record-item:active {
  opacity: 0.8;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.record-date {
  font-size: 22rpx;
  color: var(--color-text-secondary, #888888);
}