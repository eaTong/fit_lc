<view class="calendar-page">
  <!-- Month Navigator -->
  <view class="month-navigator">
    <view class="nav-btn" bindtap="onPrevMonth">
      <text class="nav-arrow">‹</text>
    </view>
    <text class="month-label">{{year}}年{{month}}月</text>
    <view class="nav-btn" bindtap="onNextMonth">
      <text class="nav-arrow">›</text>
    </view>
  </view>

  <!-- Weekday Headers -->
  <view class="weekday-header">
    <view wx:for="{{weekdays}}" wx:key="index" class="weekday-cell">
      <text class="weekday-text">{{item}}</text>
    </view>
  </view>

  <!-- Calendar Grid -->
  <view class="calendar-grid">
    <view
      wx:for="{{days}}"
      wx:key="index"
      wx:if="{{!item.empty && !item.hidden}}"
      class="day-cell {{item.isToday ? 'today' : ''}} {{item.selected ? 'selected' : ''}}"
      data-date="{{item.dateStr}}"
      bindtap="onDayTap"
    >
      <text class="day-text">{{item.day}}</text>
      <view class="record-dots">
        <view wx:if="{{item.hasWorkout}}" class="dot dot-workout"></view>
        <view wx:if="{{item.hasMeasurement}}" class="dot dot-measurement"></view>
      </view>
    </view>
  </view>

  <!-- Legend -->
  <view class="legend">
    <view class="legend-left">
      <view class="toggle-btn" bindtap="onToggleCalendar">
        <text>{{calendarExpanded ? '收起' : '展开'}}</text>
      </view>
    </view>
    <view class="legend-right">
      <view class="today-btn" bindtap="onGoToToday">
        <text>回到今天</text>
      </view>
      <view class="legend-item">
        <view class="dot dot-workout"></view>
        <text class="legend-text">训练</text>
      </view>
      <view class="legend-item">
        <view class="dot dot-measurement"></view>
        <text class="legend-text">围度</text>
      </view>
    </view>
  </view>

  <!-- All Records List -->
  <view class="records-section">
    <view class="section-header">
      <block wx:if="{{selectedDate}}">
        <text class="section-title">{{formatDisplayDate(selectedDate)}}的记录</text>
        <view class="back-btn" bindtap="onClearSelection">
          <text>返回全部</text>
        </view>
      </block>
      <block wx:else>
        <text class="section-title">全部记录</text>
        <text class="record-count">{{allRecords.length}}条</text>
      </block>
    </view>
    <scroll-view class="records-list" scroll-y>
      <block wx:if="{{selectedDate}}">
        <view
          wx:for="{{selectedDateRecords}}"
          wx:key="id"
          class="record-item"
          data-record="{{item}}"
          bindtap="onRecordTap"
        >
          <view class="record-icon">
            <text>{{item.type === 'workout' ? '💪' : '📏'}}</text>
          </view>
          <view class="record-info">
            <view class="record-header">
              <text class="record-type">{{item.type === 'workout' ? '训练记录' : '围度记录'}}</text>
              <text class="record-time">{{formatTime(item.date)}}</text>
            </view>
            <block wx:if="{{item.type === 'workout'}}">
              <text class="workout-detail" wx:for="{{item.data.exercises}}" wx:for-item="ex" wx:key="id">
                {{ex.exerciseName}} {{ex.sets}}×{{ex.reps}} {{ex.weight ? ex.weight+'kg' : ''}}
              </text>
            </block>
            <block wx:else>
              <text class="measurement-detail">{{formatMeasurementItems(item.data.items)}}</text>
            </block>
          </view>
        </view>
        <view wx:if="{{selectedDateRecords.length === 0}}" class="records-empty">
          <text>暂无记录</text>
        </view>
      </block>
      <block wx:else>
        <view
          wx:for="{{allRecords}}"
          wx:key="id"
          class="record-item"
          data-record="{{item}}"
          bindtap="onRecordTap"
        >
          <view class="record-icon">
            <text>{{item.type === 'workout' ? '💪' : '📏'}}</text>
          </view>
          <view class="record-info">
            <view class="record-header">
              <text class="record-type">{{item.type === 'workout' ? '训练记录' : '围度记录'}}</text>
              <text class="record-date">{{formatDate(item.date)}}</text>
            </view>
            <block wx:if="{{item.type === 'workout'}}">
              <text class="workout-detail" wx:for="{{item.data.exercises}}" wx:for-item="ex" wx:key="id">
                {{ex.exerciseName}} {{ex.sets}}×{{ex.reps}} {{ex.weight ? ex.weight+'kg' : ''}}
              </text>
            </block>
            <block wx:else>
              <text class="measurement-detail">{{formatMeasurementItems(item.data.items)}}</text>
            </block>
          </view>
          <view class="record-arrow">
            <text>›</text>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>
</view>