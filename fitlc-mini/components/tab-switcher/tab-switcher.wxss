.tab-switcher {
  display: flex;
  background-color: var(--color-bg-secondary);
  border-radius: 8px;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-radius: 4px;
  transition: all 0.15s;
}

.tab-item.active {
  background-color: var(--color-accent);
  color: #fff;
}