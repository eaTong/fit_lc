.dialog-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog-content {
  background-color: var(--color-bg-secondary);
  border-radius: 8px;
  width: 80%;
  max-width: 600rpx;
}

.dialog-header {
  padding: 32rpx;
  border-bottom: 1px solid var(--color-border);
}

.dialog-title { font-size: 32rpx; font-weight: 600; }

.dialog-body {
  padding: 32rpx;
}

.dialog-footer {
  display: flex;
  padding: 24rpx 32rpx;
  border-top: 1px solid var(--color-border);
}

.btn-cancel, .btn-confirm {
  flex: 1;
  margin: 0 8rpx;
}

.btn-confirm-primary { background-color: var(--color-accent); color: #fff; }
.btn-confirm-danger { background-color: var(--color-accent-red); color: #fff; }