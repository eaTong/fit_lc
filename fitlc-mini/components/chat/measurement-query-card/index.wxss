/* 围度查询卡片 - 力量感设计 */
.measurement-query-card {
  background: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4px;
  padding: 16px;
  margin: 8px 0;
  width: 100%;
  box-sizing: border-box;
}

.card-header {
  padding-bottom: 12px;
  border-bottom: 1px solid #333333;
  margin-bottom: 12px;
}

.card-title {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
}

.measurement-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.measurement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.measurement-left {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.body-part {
  font-size: 14px;
  color: #FFFFFF;
  font-weight: 500;
}

.date {
  font-size: 11px;
  color: #666666;
}

.measurement-right {
  display: flex;
  align-items: baseline;
  gap: 4px;
}

.value {
  font-size: 18px;
  font-weight: 700;
  color: #FF4500;
}

.unit {
  font-size: 12px;
  color: #888888;
}