<view class="measurement-card">
  <!-- 标题栏 -->
  <view class="card-header">
    <text class="card-title">📊 围度记录已保存</text>
    <text class="card-time">{{formatDate(data.date)}}</text>
  </view>

  <!-- 围度列表 -->
  <view class="measurement-list">
    <view class="measurement-item" wx:for="{{data.measurements}}" wx:key="body_part">
      <text class="measurement-part">{{getPartName(item.body_part)}}</text>
      <view class="measurement-value">
        <text class="value">{{item.value}}</text>
        <text class="unit">{{getUnit(item.body_part)}}</text>
      </view>
    </view>
  </view>

  <!-- 成就栏 -->
  <view class="achievement-bar" wx:if="{{getAchievements().length > 0}}">
    <text wx:for="{{getAchievements()}}" wx:key="index">{{item}}</text>
  </view>
</view>