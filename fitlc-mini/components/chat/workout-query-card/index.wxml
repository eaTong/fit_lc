<view class="workout-query-card">
  <!-- 标题栏 -->
  <view class="card-header">
    <text class="card-title">📈 近一周训练统计</text>
  </view>

  <!-- 核心数据 -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-value">{{data.summary.totalWorkouts || 0}}</text>
      <text class="stat-label">训练</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{formatVolume(data.summary.totalVolume)}}</text>
      <text class="stat-label">总容量(kg)</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="workout-list" wx:if="{{formattedWorkouts.length > 0}}">
    <view class="workout-item" wx:for="{{formattedWorkouts}}" wx:key="index">
      <text class="workout-day">{{item.dayName}} {{item.dateStr}}</text>
      <text class="workout-detail">{{item.mainExercise}} {{item.summary}}</text>
    </view>
  </view>
</view>