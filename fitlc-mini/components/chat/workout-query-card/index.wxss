/* 训练查询卡片 - 力量感设计 */
.workout-query-card {
  background: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4px;
  padding: 16px;
  margin: 8px 0;
  width: 100%;
  box-sizing: border-box;
}

.card-header {
  padding-bottom: 12px;
  border-bottom: 1px solid #333333;
  margin-bottom: 16px;
}

.card-title {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16px 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stat-value {
  font-size: 32px;
  font-weight: 700;
  color: #FF4500;
}

.stat-label {
  font-size: 12px;
  color: #888888;
}

.stat-divider {
  width: 1px;
  height: 40px;
  background: #333333;
}

.workout-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid #333333;
}

.workout-item {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: #888888;
  padding: 4px 0;
}

.workout-day {
  color: #FFFFFF;
}