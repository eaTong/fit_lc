/* 执行分析卡片 - 力量感设计 */
.analysis-card {
  background: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4px;
  padding: 16px;
  margin: 8px 0;
  width: 100%;
  box-sizing: border-box;
}

.card-header {
  padding-bottom: 12px;
  border-bottom: 1px solid #333333;
  margin-bottom: 16px;
}

.card-title {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
}

.completion-ring {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px 0;
}

.ring-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.ring-value {
  font-size: 36px;
  font-weight: 700;
  color: #FF4500;
}

.ring-label {
  font-size: 12px;
  color: #888888;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 16px 0;
  border-top: 1px solid #333333;
  margin-top: 8px;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stat-icon {
  font-size: 16px;
}

.stat-count {
  font-size: 20px;
  font-weight: 700;
  color: #FFFFFF;
}

.stat-label {
  font-size: 11px;
  color: #888888;
}

.suggestions {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding-top: 12px;
  border-top: 1px solid #333333;
  margin-top: 8px;
}

.suggestion-item {
  font-size: 13px;
  color: #888888;
  padding: 4px 0;
}