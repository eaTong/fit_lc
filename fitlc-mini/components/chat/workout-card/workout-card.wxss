/* 训练记录卡片 - 力量感设计 */
.workout-card {
  background: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4px;
  padding: 16px;
  margin: 8px 0;
  width: 100%;
  box-sizing: border-box;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 12px;
  border-bottom: 1px solid #333333;
  margin-bottom: 12px;
}

.card-title {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
}

.card-time {
  font-size: 12px;
  color: #888888;
}

.exercise-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.exercise-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.exercise-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.exercise-name {
  font-size: 16px;
  font-weight: 600;
  color: #FFFFFF;
}

.exercise-weight {
  font-size: 18px;
  font-weight: 700;
  color: #FF4500;
}

.exercise-detail {
  font-size: 13px;
  color: #888888;
  padding-left: 4px;
}

.achievement-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  padding-top: 12px;
  margin-top: 12px;
  border-top: 1px solid #333333;
  font-size: 12px;
  color: #FF4500;
}

.ai-feedback {
  margin-top: 12px;
  padding: 12px;
  background: #252525;
  border-radius: 4px;
  font-size: 14px;
  color: #FFFFFF;
  border-left: 3px solid #FF4500;
}