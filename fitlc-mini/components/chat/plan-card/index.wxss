/* 计划卡片 - 力量感设计 */
.plan-card {
  background: #1A1A1A;
  border: 2px solid #333333;
  border-radius: 4px;
  padding: 16px;
  margin: 8px 0;
  width: 100%;
  box-sizing: border-box;
}

.card-header {
  padding-bottom: 12px;
  border-bottom: 1px solid #333333;
  margin-bottom: 12px;
}

.card-title {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
}

.plan-overview {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 16px;
}

.overview-text {
  font-size: 18px;
  font-weight: 700;
  color: #FF4500;
}

.exp-text {
  font-size: 13px;
  color: #888888;
}

.schedule-preview {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 12px 0;
  border-top: 1px solid #333333;
}

.schedule-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 14px;
}

.day-name {
  color: #FFFFFF;
  font-weight: 500;
}

.muscle {
  color: #888888;
}

.action-buttons {
  display: flex;
  gap: 12px;
  margin-top: 16px;
  padding-top: 12px;
  border-top: 1px solid #333333;
}

.btn {
  flex: 1;
  height: 36px;
  line-height: 36px;
  font-size: 14px;
  border-radius: 4px;
  text-align: center;
}

.btn-primary {
  background: #FF4500;
  color: #FFFFFF;
  border: none;
}

.btn-secondary {
  background: transparent;
  color: #FFFFFF;
  border: 2px solid #333333;
}