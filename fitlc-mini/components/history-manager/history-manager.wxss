.history-manager-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.history-manager-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.history-manager-content {
  position: relative;
  width: 100%;
  max-height: 80vh;
  background-color: #1A1A1A;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

/* Header */
.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1px solid #333;
}

.history-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.history-close {
  font-size: 40rpx;
  color: #888;
  padding: 10rpx;
}

/* Message List */
.message-list {
  flex: 1;
  max-height: 60vh;
  padding: 0 32rpx;
}

.date-section {
  margin-bottom: 24rpx;
}

.date-header {
  padding: 16rpx 0;
}

.date-label {
  font-size: 24rpx;
  color: #888;
}

.message-item {
  background-color: #252525;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.message-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.message-role {
  font-size: 24rpx;
  font-weight: 600;
}

.message-role.user {
  color: #FF4500;
}

.message-role.assistant {
  color: #4CAF50;
}

.message-time {
  font-size: 24rpx;
  color: #888;
}

.message-content {
  font-size: 28rpx;
  color: #FFFFFF;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.message-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #DC143C;
  padding: 8rpx 16rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #888;
}

/* Footer */
.history-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #333;
}

.clear-all-btn {
  background-color: transparent;
  border: 2rpx solid #DC143C;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
}

.clear-all-btn text {
  font-size: 28rpx;
  color: #DC143C;
  font-weight: 600;
}