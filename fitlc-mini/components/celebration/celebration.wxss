.celebration-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.6);
}

.celebration-content {
  width: 560rpx;
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #252525 100%);
  border-radius: 16rpx;
  border: 2rpx solid #333;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.5);
}

.emoji-large {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4500;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
}

.pr-detail {
  margin: 20rpx 0;
}

.pr-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.pr-type {
  font-size: 28rpx;
  color: #888;
  margin-left: 12rpx;
}

.pr-change {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.pr-unit {
  font-size: 28rpx;
  color: #888;
  margin-left: 8rpx;
}

.badge-list,
.milestone-list {
  margin-top: 20rpx;
}

.badge-item,
.milestone-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  background-color: #333;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #fff;
  margin: 8rpx;
}