.gallery-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary, #0A0A0A);
}

.page-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary, #FFFFFF);
}

/* Month Selector */
.month-selector {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.month-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-btn {
  font-size: 32rpx;
  color: var(--color-text-primary, #FFFFFF);
  font-weight: 600;
}

.month-picker {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 16rpx;
}

.month-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
}

/* Loading */
.loading-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
}

/* Empty State */
.empty-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-secondary, #888888);
}

/* Content Container */
.content-container {
  flex: 1;
  padding: 16rpx 24rpx;
}

/* Date Group */
.date-group {
  margin-bottom: 32rpx;
}

.date-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary, #888888);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* Photo Grid - 3 columns */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.photo-item {
  width: calc(33.33% - 8rpx);
  aspect-ratio: 1;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-radius: 4rpx;
  overflow: hidden;
  border: 1px solid var(--color-border, #333333);
}

.photo-image {
  width: 100%;
  height: 100%;
}