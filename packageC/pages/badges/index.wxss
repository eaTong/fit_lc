.badges-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary, #0A0A0A);
}

.badges-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-bottom: 1px solid var(--color-border, #333333);
  flex-shrink: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary, #FFFFFF);
}

/* Loading */
.loading-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888888);
}

/* Empty State */
.empty-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-primary, #FFFFFF);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-secondary, #888888);
  text-align: center;
}

/* Badges Container */
.badges-container {
  flex: 1;
  padding: 24rpx;
}

/* Badges Grid - 3 columns */
.badges-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

/* Badge Card */
.badge-card {
  width: 32%;
  background-color: var(--color-bg-secondary, #1A1A1A);
  border-radius: 4rpx;
  padding: 24rpx 16rpx;
  margin-bottom: 24rpx;
  border: 1px solid var(--color-border, #333333);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.badge-card.earned {
  border-color: var(--color-accent, #FF4500);
}

.badge-card.locked {
  opacity: 0.6;
}

.badge-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: var(--color-bg-tertiary, #252525);
  border-radius: 4rpx;
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.badge-card.earned .badge-icon {
  background-color: var(--color-bg-tertiary, #252525);
}

.badge-card.locked .badge-icon {
  filter: grayscale(100%);
}

.badge-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.badge-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary, #FFFFFF);
  text-align: center;
  margin-bottom: 8rpx;
}

.badge-date {
  font-size: 22rpx;
  color: var(--color-accent, #FF4500);
  text-align: center;
}

.badge-condition {
  font-size: 22rpx;
  color: var(--color-text-secondary, #888888);
  text-align: center;
}