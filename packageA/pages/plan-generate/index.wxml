<view class="page-container">
  <!-- Header -->
  <view class="header">
    <view class="back-btn" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="title">生成训练计划</text>
    <view class="placeholder"></view>
  </view>

  <!-- Form -->
  <view class="form-container">
    <!-- Goal Picker -->
    <view class="form-item">
      <text class="form-label">训练目标</text>
      <picker
        mode="selector"
        range="{{goalRange}}"
        value="{{goalValues.indexOf(formData.goal)}}"
        bindchange="onGoalChange"
      >
        <view class="picker-value">
          <text class="picker-text">{{goalRange[goalValues.indexOf(formData.goal)]}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- Frequency Picker -->
    <view class="form-item">
      <text class="form-label">每周训练天数</text>
      <picker
        mode="selector"
        range="{{['1天', '2天', '3天', '4天', '5天', '6天', '7天']}}"
        value="{{formData.frequency - 1}}"
        bindchange="onFrequencyChange"
      >
        <view class="picker-value">
          <text class="picker-text">{{formData.frequency}}天/周</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- Duration Picker -->
    <view class="form-item">
      <text class="form-label">每次训练时长</text>
      <picker
        mode="selector"
        range="{{durationRange}}"
        value="{{durationValues.indexOf(formData.durationMinutes)}}"
        bindchange="onDurationChange"
      >
        <view class="picker-value">
          <text class="picker-text">{{durationRange[durationValues.indexOf(formData.durationMinutes)]}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- Focus Areas Picker (Multi-select) -->
    <view class="form-item">
      <text class="form-label">部位重点（可选）</text>
      <picker
        mode="multiSelector"
        range="{{focusAreaOptions}}"
        value="{{selectedFocusAreas}}"
        bindchange="onFocusAreaChange"
      >
        <view class="picker-value">
          <text class="picker-text {{selectedFocusAreas.length === 0 ? 'placeholder' : ''}}">
            {{selectedFocusAreas.length > 0 ? selectedFocusAreas.join('、') : '未选择'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- Error Message -->
    <view wx:if="{{error}}" class="error-text">
      <text>{{error}}</text>
    </view>

    <!-- Submit Button -->
    <view class="submit-btn {{isLoading ? 'loading' : ''}}" bindtap="onSubmit">
      <text wx:if="{{!isLoading}}" class="submit-btn-text">生成计划</text>
      <text wx:else class="submit-btn-text">生成中...</text>
    </view>
  </view>
</view>